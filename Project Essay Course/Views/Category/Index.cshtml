@model IEnumerable<Project_Essay_Course.Models.Category>
@{
    ViewData["Title"] = "Quản Lý Danh Mục";    
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

@section Styles {
<style>
.cat-manage-page { max-width: 1100px; margin: 3rem auto; padding: 0 2rem; }

.page-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;
    padding-bottom: 1.5rem; border-bottom: 1px solid var(--light-gray);
}
.page-eyebrow { font-size:.68rem; letter-spacing:.22em; text-transform:uppercase; color:var(--accent); margin-bottom:.4rem; }
.page-title   { font-family:var(--serif); font-size:clamp(1.6rem,3vw,2.4rem); font-weight:300; }
.page-title em { font-style:italic; }

.btn-create {
    display:inline-flex; align-items:center; gap:.5rem;
    padding:.8rem 1.8rem; background:var(--black); color:var(--white);
    border:1px solid var(--black); font-family:var(--sans);
    font-size:.74rem; letter-spacing:.14em; text-transform:uppercase;
    text-decoration:none; transition:background var(--transition), color var(--transition);
}
.btn-create:hover { background:var(--white); color:var(--black); }
.btn-create svg { width:14px; height:14px; stroke-width:2; }

/* Stats */
.stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:2rem; }
.stat-card { border:1px solid var(--light-gray); padding:1.2rem 1.6rem; display:flex; align-items:center; gap:1rem; }
.stat-icon { width:36px; height:36px; background:var(--cream); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.stat-icon svg { width:16px; height:16px; stroke-width:1.5; color:var(--charcoal); }
.stat-num   { font-family:var(--serif); font-size:1.5rem; font-weight:600; line-height:1; }
.stat-label { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:#999; margin-top:.15rem; }

/* Filters */
.filters-row {
    display:flex; gap:.8rem; margin-bottom:1rem; flex-wrap:wrap; align-items:flex-end;
}
.filter-group { display:flex; flex-direction:column; gap:.35rem; }
.filter-label { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:#999; }
.filter-input, .filter-select {
    padding:.6rem .9rem; border:1px solid var(--light-gray);
    background:var(--white); font-family:var(--sans); font-size:.84rem;
    color:var(--black); outline:none; transition:border-color var(--transition);
}
.filter-input:focus, .filter-select:focus { border-color:var(--black); }
.search-wrap { position:relative; }
.search-wrap svg { position:absolute; left:.8rem; top:50%; transform:translateY(-50%); width:14px; height:14px; stroke-width:1.6; color:#bbb; }
.search-wrap .filter-input { padding-left:2.2rem; min-width:260px; }
.btn-filter { padding:.6rem 1.4rem; border:1px solid var(--black); background:var(--black); color:var(--white); font-family:var(--sans); font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; cursor:pointer; transition:all .2s; }
.btn-filter:hover { background:var(--white); color:var(--black); }
.btn-reset  { padding:.6rem 1rem; border:1px solid var(--light-gray); background:none; font-family:var(--sans); font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; cursor:pointer; color:#999; transition:all .2s; text-decoration:none; display:inline-flex; align-items:center; }
.btn-reset:hover { border-color:var(--black); color:var(--black); }

/* Category tree table */
.cat-table { width:100%; border-collapse:collapse; font-size:.85rem; }
.cat-table thead th { padding:.75rem 1rem; font-size:.65rem; letter-spacing:.16em; text-transform:uppercase; color:#999; font-weight:400; border-bottom:2px solid var(--light-gray); text-align:left; white-space:nowrap; }
.cat-table tbody tr { border-bottom:1px solid rgba(235,235,235,.7); transition:background .15s; }
.cat-table tbody tr:hover { background:var(--cream); }
.cat-table tbody td { padding:.9rem 1rem; vertical-align:middle; }

/* Root row style */
.cat-row-root td:first-child { font-weight:500; }
.cat-row-root { background:rgba(245,240,232,.3); }

/* Sub row indent */
.cat-name-sub { padding-left:1.5rem; display:flex; align-items:center; gap:.6rem; }
.sub-indent-icon { color:#ddd; flex-shrink:0; }
.sub-indent-icon svg { width:14px; height:14px; stroke-width:1.8; }

/* Image thumb */
.cat-img-thumb {
    width:42px; height:42px; object-fit:cover; border-radius:2px;
    background:var(--cream); display:block;
}
.cat-img-placeholder {
    width:42px; height:42px; background:var(--cream);
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.cat-img-placeholder svg { width:18px; height:18px; color:var(--stone); stroke-width:1; }

.cat-cell { display:flex; align-items:center; gap:.9rem; }
.cat-cell-name  { font-size:.9rem; color:var(--black); }
.cat-cell-slug  { font-size:.72rem; color:#bbb; font-family:monospace; margin-top:.15rem; }

/* Status */
.status-badge { display:inline-flex; align-items:center; gap:.35rem; padding:.25rem .7rem; font-size:.65rem; letter-spacing:.1em; text-transform:uppercase; }
.status-badge::before { content:''; width:6px; height:6px; border-radius:50%; }
.badge-active::before   { background:#16a34a; }
.badge-active    { color:#15803d; background:#f0fdf4; border:1px solid #bbf7d0; }
.badge-inactive::before { background:#bbb; }
.badge-inactive  { color:#777; background:#f5f5f5; border:1px solid #e0e0e0; }

/* Order badge */
.order-badge { display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; background:var(--cream); border:1px solid var(--light-gray); font-size:.78rem; color:var(--charcoal); font-family:monospace; }

/* Actions */
.action-group { display:flex; gap:.4rem; flex-wrap:wrap; }
.action-btn { padding:.38rem .8rem; border:1px solid var(--light-gray); background:none; font-family:var(--sans); font-size:.68rem; letter-spacing:.1em; text-transform:uppercase; color:var(--charcoal); text-decoration:none; transition:all .2s; white-space:nowrap; }
.action-btn:hover { border-color:var(--black); color:var(--black); }
.action-btn-danger { color:var(--danger); border-color:rgba(192,57,43,.3); }
.action-btn-danger:hover { background:var(--danger); color:var(--white); border-color:var(--danger); }
.toggle-form  { display:inline; }
.toggle-btn { padding:.38rem .8rem; border:1px solid var(--light-gray); background:none; font-family:var(--sans); font-size:.68rem; letter-spacing:.1em; text-transform:uppercase; color:var(--charcoal); cursor:pointer; transition:all .2s; }
.toggle-btn:hover { border-color:var(--black); color:var(--black); }

/* Empty */
.empty-state { text-align:center; padding:5rem 2rem; color:#bbb; }
.empty-state svg { width:48px; height:48px; stroke-width:1; margin:0 auto 1rem; }

@@media (max-width:768px) { .stats-row { grid-template-columns:repeat(2,1fr); } }
@@media (max-width:480px) { .stats-row { grid-template-columns:1fr; } }
</style>
}

<div class="cat-manage-page">

    <div class="page-header">
        <div>
            <div class="page-eyebrow">Quản Trị Viên</div>
            <h1 class="page-title">Quản Lý <em>Danh Mục</em></h1>
        </div>
        <a asp-action="Create" class="btn-create">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 5v14M5 12h14"/></svg>
            Thêm Danh Mục
        </a>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 7h18M3 12h18M3 17h18"/></svg>
            </div>
            <div>
                <div class="stat-num">@Model.Count()</div>
                <div class="stat-label">Tổng danh mục</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3H8v4h8V3z"/></svg>
            </div>
            <div>
                <div class="stat-num">@ViewBag.TotalRoot</div>
                <div class="stat-label">Danh mục gốc</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/></svg>
            </div>
            <div>
                <div class="stat-num">@ViewBag.TotalSub</div>
                <div class="stat-label">Sub-category</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
                <div class="stat-num">@ViewBag.TotalActive</div>
                <div class="stat-label">Đang kích hoạt</div>
            </div>
        </div>
    </div>

    <form asp-action="Index" method="get" class="filters-row">
        <div class="filter-group">
            <div class="filter-label">Tìm kiếm</div>
            <div class="search-wrap">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <input type="text" name="search" class="filter-input"
                       placeholder="Tên, slug..." value="@ViewBag.Search" />
            </div>
        </div>
        <div class="filter-group">
            <div class="filter-label">Trạng thái</div>
            <select name="isActive" class="filter-select">
                <option value="">Tất cả</option>
                <option value="true"  selected="@(ViewBag.IsActive == true)">Kích hoạt</option>
                <option value="false" selected="@(ViewBag.IsActive == false)">Đã ẩn</option>
            </select>
        </div>
        <button type="submit" class="btn-filter">Lọc</button>
        <a asp-action="Index" class="btn-reset">Xóa lọc</a>
    </form>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 7h18M3 12h18M3 17h18"/></svg>
            <p>Chưa có danh mục nào. <a asp-action="Create" style="color:var(--black);border-bottom:1px solid">Tạo ngay</a></p>
        </div>
    }
    else
    {
        <table class="cat-table">
            <thead>
                <tr>
                    <th>Danh mục</th>
                    <th>Ảnh</th>
                    <th>Danh mục cha</th>
                    <th>Sản phẩm</th>
                    <th>Thứ tự</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{
                    // Render root categories trước, rồi sub-category ngay dưới cha
                    var roots = Model.Where(c => c.ParentId == null)
                                     .OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name);
                }
                @foreach (var root in roots)
                {
                    <tr class="cat-row-root">
                        <td>
                            <div class="cat-cell">
                                <div>
                                    <div class="cat-cell-name">@root.Name</div>
                                    <div class="cat-cell-slug">/@root.Slug</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(root.ImagePath))
                            {
                                <img class="cat-img-thumb" src="@root.ImagePath" alt="@root.Name" />
                            }
                            else
                            {
                                <div class="cat-img-placeholder">
                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                                </div>
                            }
                        </td>
                        <td style="color:#bbb;font-size:.8rem">—</td>
                        <td>@root.Products.Count(p => p.IsActive)</td>
                        <td><span class="order-badge">@root.DisplayOrder</span></td>
                        <td>
                            @if (root.IsActive) { <span class="status-badge badge-active">Kích hoạt</span> }
                            else { <span class="status-badge badge-inactive">Đã ẩn</span> }
                        </td>
                        <td>
                            <div class="action-group">
                                <a asp-action="Detail" asp-route-id="@root.CategoryId" class="action-btn">Xem</a>
                                <a asp-action="Edit"   asp-route-id="@root.CategoryId" class="action-btn">Sửa</a>
                                <form asp-action="ToggleActive" asp-route-id="@root.CategoryId" method="post" class="toggle-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="toggle-btn">@(root.IsActive ? "Ẩn" : "Hiện")</button>
                                </form>
                                <a asp-action="Delete" asp-route-id="@root.CategoryId" class="action-btn action-btn-danger">Xóa</a>
                            </div>
                        </td>
                    </tr>

                    @foreach (var sub in root.Children.OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name))
                    {
                        <tr>
                            <td>
                                <div class="cat-name-sub">
                                    <span class="sub-indent-icon">
                                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6" style="opacity:.4"/></svg>
                                    </span>
                                    <div>
                                        <div class="cat-cell-name" style="font-size:.85rem">@sub.Name</div>
                                        <div class="cat-cell-slug">/@sub.Slug</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(sub.ImagePath))
                                {
                                    <img class="cat-img-thumb" src="@sub.ImagePath" alt="@sub.Name" />
                                }
                                else
                                {
                                    <div class="cat-img-placeholder"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div>
                                }
                            </td>
                            <td style="font-size:.8rem;color:#888">@root.Name</td>
                            <td>@sub.Products.Count(p => p.IsActive)</td>
                            <td><span class="order-badge">@sub.DisplayOrder</span></td>
                            <td>
                                @if (sub.IsActive) { <span class="status-badge badge-active">Kích hoạt</span> }
                                else { <span class="status-badge badge-inactive">Đã ẩn</span> }
                            </td>
                            <td>
                                <div class="action-group">
                                    <a asp-action="Detail" asp-route-id="@sub.CategoryId" class="action-btn">Xem</a>
                                    <a asp-action="Edit"   asp-route-id="@sub.CategoryId" class="action-btn">Sửa</a>
                                    <form asp-action="ToggleActive" asp-route-id="@sub.CategoryId" method="post" class="toggle-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="toggle-btn">@(sub.IsActive ? "Ẩn" : "Hiện")</button>
                                    </form>
                                    <a asp-action="Delete" asp-route-id="@sub.CategoryId" class="action-btn action-btn-danger">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }

</div>
