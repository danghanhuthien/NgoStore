@model Project_Essay_Course.Models.Category
@{
    ViewData["Title"] = "Xóa Danh Mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    bool hasChildren = Model.Children.Any();
    bool hasProducts = Model.Products.Any();
    bool canDelete   = !hasChildren && !hasProducts;
}

@section Styles {
<style>
.delete-page { max-width: 600px; margin: 3rem auto; padding: 0 2rem; }
.form-breadcrumb { display:flex; align-items:center; gap:.6rem; font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:#999; margin-bottom:2.5rem; }
.form-breadcrumb a { color:#999; text-decoration:none; transition:color .2s; }
.form-breadcrumb a:hover { color:var(--black); }
.form-breadcrumb svg { width:12px; height:12px; stroke-width:2; }

.delete-eyebrow { font-size:.68rem; letter-spacing:.22em; text-transform:uppercase; color:var(--danger); margin-bottom:.6rem; }
.delete-title   { font-family:var(--serif); font-size:clamp(1.6rem,3vw,2.4rem); font-weight:300; margin-bottom:2rem; }
.delete-title em { font-style:italic; color:var(--danger); }

/* Banner */
.warning-banner { display:flex; gap:1rem; align-items:flex-start; padding:1.2rem 1.4rem; margin-bottom:2rem; }
.banner-danger  { background:#fff5f5; border:1px solid rgba(192,57,43,.25); border-left:4px solid var(--danger); }
.banner-block   { background:#fffbeb; border:1px solid rgba(245,158,11,.25); border-left:4px solid #f59e0b; }
.banner-icon { width:36px; height:36px; flex-shrink:0; display:flex; align-items:center; justify-content:center; border-radius:50%; }
.banner-danger .banner-icon { background:rgba(192,57,43,.1); color:var(--danger); }
.banner-block  .banner-icon { background:rgba(245,158,11,.1); color:#d97706; }
.banner-icon svg { width:18px; height:18px; stroke-width:2; }
.banner-text { font-size:.82rem; line-height:1.65; }
.banner-danger .banner-text { color:#8b2c2c; }
.banner-block  .banner-text { color:#92400e; }
.banner-text strong { display:block; font-size:.86rem; margin-bottom:.3rem; }

/* Category preview */
.cat-preview { display:flex; gap:1.2rem; align-items:center; border:1px solid var(--light-gray); padding:1.2rem; margin-bottom:2rem; background:var(--cream); }
.cat-preview-img { width:64px; height:64px; object-fit:cover; flex-shrink:0; }
.cat-preview-placeholder { width:64px; height:64px; flex-shrink:0; background:var(--light-gray); display:flex; align-items:center; justify-content:center; }
.cat-preview-placeholder svg { width:24px; height:24px; color:var(--stone); stroke-width:1; }
.cat-preview-name { font-family:var(--serif); font-size:1.1rem; margin-bottom:.25rem; }
.cat-preview-meta { font-size:.78rem; color:#999; }

/* Block list */
.block-list { padding:1.2rem 1.4rem; background:var(--cream); margin-bottom:2rem; border:1px solid var(--stone); }
.block-list-title { font-size:.68rem; letter-spacing:.14em; text-transform:uppercase; color:var(--charcoal); margin-bottom:.8rem; }
.block-list ul { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:.5rem; }
.block-list li { display:flex; gap:.6rem; align-items:center; font-size:.82rem; color:var(--charcoal); }
.block-list li::before { content:'↳'; color:var(--stone); flex-shrink:0; }
.block-list li a { color:var(--black); border-bottom:1px solid var(--light-gray); text-decoration:none; }
.block-list li a:hover { border-color:var(--black); }

/* Consequences */
.consequences { padding:1.2rem 1.4rem; background:var(--cream); margin-bottom:2rem; border:1px solid var(--stone); }
.consequences-title { font-size:.68rem; letter-spacing:.14em; text-transform:uppercase; color:var(--charcoal); margin-bottom:.7rem; }
.consequences ul { padding-left:0; margin:0; list-style:none; display:flex; flex-direction:column; gap:.4rem; }
.consequences li { display:flex; gap:.6rem; font-size:.82rem; color:var(--charcoal); line-height:1.6; }
.consequences li::before { content:'✕'; color:var(--danger); font-size:.8rem; flex-shrink:0; margin-top:.1rem; }

/* Actions */
.form-actions { display:flex; gap:1rem; align-items:center; flex-wrap:wrap; }
.btn-delete { padding:.9rem 2rem; background:var(--danger); color:var(--white); border:1px solid var(--danger); font-family:var(--sans); font-size:.78rem; letter-spacing:.16em; text-transform:uppercase; cursor:pointer; transition:background .25s; }
.btn-delete:hover { background:#a93226; border-color:#a93226; }
.btn-cancel { padding:.9rem 2rem; background:none; color:var(--charcoal); border:1px solid var(--light-gray); font-family:var(--sans); font-size:.78rem; letter-spacing:.16em; text-transform:uppercase; text-decoration:none; transition:all .25s; }
.btn-cancel:hover { border-color:var(--black); color:var(--black); }
</style>
}

<div class="delete-page">

    <div class="form-breadcrumb">
        <a asp-action="Index">Danh mục</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <a asp-action="Detail" asp-route-id="@Model.CategoryId">@Model.Name</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>Xóa</span>
    </div>

    <div class="delete-eyebrow">⚠ Vùng nguy hiểm</div>
    <h1 class="delete-title">Xóa <em>Danh Mục</em></h1>

    @* ── Blocked: còn sub-category hoặc sản phẩm ── *@
    @if (!canDelete)
    {
        <div class="warning-banner banner-block">
            <div class="banner-icon">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
            </div>
            <div class="banner-text">
                <strong>Không thể xóa danh mục này</strong>
                Bạn cần xử lý các ràng buộc bên dưới trước khi xóa.
            </div>
        </div>

        @if (hasChildren)
        {
            <div class="block-list">
                <div class="block-list-title">@Model.Children.Count danh mục con — cần xóa hoặc chuyển cha trước</div>
                <ul>
                    @foreach (var child in Model.Children)
                    {
                        <li>
                            <a asp-action="Detail" asp-route-id="@child.CategoryId">@child.Name</a>
                            <span style="color:#bbb">/@child.Slug</span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (hasProducts)
        {
            <div class="block-list">
                <div class="block-list-title">@Model.Products.Count sản phẩm — cần chuyển sang danh mục khác trước</div>
                <ul>
                    @foreach (var p in Model.Products.Take(5))
                    {
                        <li>
                            <a asp-controller="Product" asp-action="AdminDetail" asp-route-id="@p.ProductId">@p.Name</a>
                        </li>
                    }
                    @if (Model.Products.Count > 5)
                    {
                        <li style="color:#bbb">... và @(Model.Products.Count - 5) sản phẩm khác</li>
                    }
                </ul>
            </div>
        }

        <div class="form-actions">
            <a asp-action="Edit"   asp-route-id="@Model.CategoryId" class="btn-cancel">Chỉnh sửa danh mục</a>
            <a asp-action="Index"  class="btn-cancel">Quay lại danh sách</a>
        </div>
    }
    else
    {
        @* ── Can delete ── *@
        <div class="warning-banner banner-danger">
            <div class="banner-icon">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <div class="banner-text">
                <strong>Hành động này không thể hoàn tác!</strong>
                Danh mục và ảnh đại diện sẽ bị xóa vĩnh viễn khỏi hệ thống.
            </div>
        </div>

        <div class="cat-preview">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img class="cat-preview-img" src="@Model.ImagePath" alt="@Model.Name" />
            }
            else
            {
                <div class="cat-preview-placeholder">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
            }
            <div>
                <div class="cat-preview-name">@Model.Name</div>
                <div class="cat-preview-meta">
                    /@Model.Slug &nbsp;·&nbsp;
                    @(Model.Parent != null ? $"Thuộc: {Model.Parent.Name}" : "Danh mục gốc")
                </div>
            </div>
        </div>

        <div class="consequences">
            <div class="consequences-title">Dữ liệu sẽ bị xóa vĩnh viễn</div>
            <ul>
                <li>Thông tin danh mục (tên, slug, thứ tự)</li>
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <li>File ảnh đại diện trên server</li>
                }
            </ul>
        </div>

        <form asp-action="Delete" asp-route-id="@Model.CategoryId" method="post">
            @Html.AntiForgeryToken()
            <div class="form-actions">
                <button type="submit" class="btn-delete">Xóa Vĩnh Viễn</button>
                <a asp-action="Detail" asp-route-id="@Model.CategoryId" class="btn-cancel">Hủy — Giữ Danh Mục</a>
            </div>
        </form>
    }

</div>
