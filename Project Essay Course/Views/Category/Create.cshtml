@model Project_Essay_Course.ViewModels.Category_ViewModel.CategoryCreateViewModel
@{
    ViewData["Title"] = "Thêm Danh Mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

@section Styles {
<style>
.cat-form-page { max-width: 760px; margin: 3rem auto; padding: 0 2rem; }
.form-breadcrumb { display:flex; align-items:center; gap:.6rem; font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:#999; margin-bottom:2.5rem; }
.form-breadcrumb a { color:#999; text-decoration:none; transition:color .2s; }
.form-breadcrumb a:hover { color:var(--black); }
.form-breadcrumb svg { width:12px; height:12px; stroke-width:2; }
.form-eyebrow { font-size:.68rem; letter-spacing:.22em; text-transform:uppercase; color:var(--accent); margin-bottom:.5rem; }
.form-title   { font-family:var(--serif); font-size:clamp(1.6rem,3vw,2.4rem); font-weight:300; margin-bottom:2.5rem; }
.form-title em { font-style:italic; }
.form-card    { border:1px solid var(--light-gray); padding:2rem 2.5rem; margin-bottom:1.4rem; }
.form-card-title { font-size:.7rem; letter-spacing:.2em; text-transform:uppercase; color:var(--accent); margin-bottom:1.8rem; padding-bottom:.8rem; border-bottom:1px solid var(--light-gray); }
.field-group  { margin-bottom:1.5rem; }
.field-label  { display:block; font-size:.7rem; letter-spacing:.14em; text-transform:uppercase; color:var(--charcoal); margin-bottom:.5rem; }
.field-label .req { color:var(--danger); margin-left:.2rem; }
.field-input, .field-select { width:100%; padding:.85rem 1rem; border:1px solid var(--light-gray); background:var(--white); font-family:var(--sans); font-size:.9rem; color:var(--black); outline:none; transition:border-color var(--transition); }
.field-input:focus, .field-select:focus { border-color:var(--black); }
.field-error { font-size:.72rem; color:var(--danger); margin-top:.4rem; display:block; }
.field-hint  { font-size:.72rem; color:#999; margin-top:.4rem; line-height:1.5; }
.slug-wrap { position:relative; }
.slug-prefix { position:absolute; left:1rem; top:50%; transform:translateY(-50%); font-size:.82rem; color:#bbb; pointer-events:none; }
.slug-wrap .field-input { padding-left:5.5rem; }
.field-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.checkbox-group { display:flex; align-items:center; gap:.7rem; cursor:pointer; }
.checkbox-group input[type=checkbox] { accent-color:var(--black); width:16px; height:16px; }
.checkbox-group span { font-size:.85rem; color:var(--charcoal); }
.val-summary { background:#fef2f2; border-left:3px solid var(--danger); padding:.9rem 1rem; margin-bottom:1.4rem; font-size:.82rem; color:var(--danger); }
.val-summary ul { padding-left:1.2rem; margin:0; }

/* Image upload */
.image-upload-area { border:2px dashed var(--light-gray); padding:2rem; text-align:center; cursor:pointer; position:relative; transition:border-color .25s; }
.image-upload-area:hover { border-color:var(--black); }
.image-upload-area input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
.upload-icon svg { width:32px; height:32px; margin:0 auto .6rem; color:var(--stone); stroke-width:1.2; }
.upload-text { font-size:.85rem; color:var(--charcoal); }
.upload-hint { font-size:.72rem; color:#bbb; margin-top:.25rem; }
.preview-wrap { margin-top:1rem; display:none; }
.preview-img-box { width:100px; height:100px; object-fit:cover; border:1px solid var(--light-gray); }

/* Actions */
.form-actions { display:flex; gap:1rem; align-items:center; margin-top:2rem; }
.btn-submit { padding:.9rem 2.5rem; background:var(--black); color:var(--white); border:1px solid var(--black); font-family:var(--sans); font-size:.78rem; font-weight:400; letter-spacing:.16em; text-transform:uppercase; cursor:pointer; transition:all var(--transition); }
.btn-submit:hover { background:var(--charcoal); }
.btn-cancel { padding:.9rem 2rem; background:none; color:var(--charcoal); border:1px solid var(--light-gray); font-family:var(--sans); font-size:.78rem; letter-spacing:.16em; text-transform:uppercase; text-decoration:none; transition:all .25s; }
.btn-cancel:hover { border-color:var(--black); color:var(--black); }
</style>
}

<div class="cat-form-page">

    <div class="form-breadcrumb">
        <a asp-action="Index">Danh mục</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>Thêm mới</span>
    </div>

    <div class="form-eyebrow">Quản Trị Viên</div>
    <h1 class="form-title">Thêm <em>Danh Mục Mới</em></h1>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="val-summary">
            <ul>@foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors)) { <li>@e.ErrorMessage</li> }</ul>
        </div>
    }

    <form asp-action="Create" method="post" enctype="multipart/form-data" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-card">
            <div class="form-card-title">Thông Tin Danh Mục</div>

            <div class="field-group">
                <label class="field-label" asp-for="Name">Tên danh mục <span class="req">*</span></label>
                <input asp-for="Name" class="field-input" placeholder="VD: Nữ, Áo, Bánh sinh nhật..."
                       oninput="autoSlug(this.value)" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="Slug">Slug (URL) <span class="req">*</span></label>
                <div class="slug-wrap">
                    <span class="slug-prefix">/category/</span>
                    <input asp-for="Slug" class="field-input" id="slug-input" placeholder="nu, ao, banh-sinh-nhat..." />
                </div>
                <span asp-validation-for="Slug" class="field-error"></span>
                <span class="field-hint">Chỉ dùng chữ thường, số và dấu -. Tự động tạo từ tên.</span>
            </div>

            <div class="field-grid-2">
                <div class="field-group">
                    <label class="field-label" asp-for="ParentId">Danh mục cha</label>
                    <select asp-for="ParentId" asp-items="ViewBag.ParentCategories" class="field-select"></select>
                    <span class="field-hint">Để trống nếu đây là danh mục gốc.</span>
                </div>
                <div class="field-group">
                    <label class="field-label" asp-for="DisplayOrder">Thứ tự hiển thị</label>
                    <input asp-for="DisplayOrder" type="number" class="field-input" min="0" placeholder="0" />
                    <span class="field-hint">Số nhỏ hơn hiển thị trước.</span>
                </div>
            </div>

            <div class="field-group">
                <label class="checkbox-group">
                    <input asp-for="IsActive" type="checkbox" />
                    <span>Kích hoạt (hiển thị trên website)</span>
                </label>
            </div>
        </div>

        <div class="form-card">
            <div class="form-card-title">Ảnh Danh Mục</div>
            <div class="image-upload-area">
                <input type="file" asp-for="ImageFile" accept="image/jpeg,image/png,image/webp"
                       onchange="previewImage(this)" />
                <div class="upload-icon">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                </div>
                <div class="upload-text">Click để chọn ảnh</div>
                <div class="upload-hint">JPG, PNG, WebP · Tối đa 5MB</div>
            </div>
            <div class="preview-wrap" id="preview-wrap">
                <img id="preview-img" class="preview-img-box" src="" alt="preview" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Tạo Danh Mục</button>
            <a asp-action="Index" class="btn-cancel">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
function autoSlug(val) {
    const slug = val.toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
        .replace(/đ/g,'d').replace(/Đ/g,'d')
        .replace(/[^a-z0-9\s-]/g,'')
        .trim().replace(/\s+/g,'-');
    document.getElementById('slug-input').value = slug;
}
function previewImage(input) {
    if (!input.files[0]) return;
    const wrap = document.getElementById('preview-wrap');
    const img  = document.getElementById('preview-img');
    const reader = new FileReader();
    reader.onload = e => { img.src = e.target.result; wrap.style.display = 'block'; };
    reader.readAsDataURL(input.files[0]);
}
</script>
}
