@model Project_Essay_Course.ViewModels.Order_ViewModel.OrderAdminListViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Lý Đơn Hàng";
}

@section Styles {
<style>
.orders-admin-page { max-width: 1300px; margin: 3rem auto; padding: 0 2rem; }
.page-header { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2rem; flex-wrap:wrap; gap:1rem; padding-bottom:1.5rem; border-bottom:1px solid var(--light-gray); }
.page-eyebrow { font-size:.68rem; letter-spacing:.22em; text-transform:uppercase; color:var(--accent); margin-bottom:.4rem; }
.page-title { font-family:var(--serif); font-size:clamp(1.6rem,3vw,2.4rem); font-weight:300; }
.page-title em { font-style:italic; }

/* Stats */
.stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:2rem; }
.stat-card { border:1px solid var(--light-gray); padding:1.2rem 1.6rem; display:flex; align-items:center; gap:1rem; }
.stat-icon { width:36px; height:36px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.stat-icon svg { width:16px; height:16px; stroke-width:1.5; }
.stat-num { font-family:var(--serif); font-size:1.5rem; font-weight:600; line-height:1; }
.stat-label { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:#999; margin-top:.15rem; }

/* Filter */
.filter-row { display:flex; gap:.8rem; margin-bottom:1rem; flex-wrap:wrap; align-items:flex-end; }
.filter-group { display:flex; flex-direction:column; gap:.35rem; }
.filter-label { font-size:.65rem; letter-spacing:.12em; text-transform:uppercase; color:#999; }
.filter-input, .filter-select { padding:.6rem .9rem; border:1px solid var(--light-gray); background:var(--white); font-family:var(--sans); font-size:.84rem; color:var(--black); outline:none; transition:border-color var(--transition); }
.filter-input:focus, .filter-select:focus { border-color:var(--black); }
.search-wrap { position:relative; }
.search-wrap svg { position:absolute; left:.8rem; top:50%; transform:translateY(-50%); width:14px; height:14px; stroke-width:1.6; color:#bbb; }
.search-wrap .filter-input { padding-left:2.2rem; min-width:260px; }
.btn-filter { padding:.6rem 1.4rem; border:1px solid var(--black); background:var(--black); color:var(--white); font-family:var(--sans); font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; cursor:pointer; transition:all .2s; }
.btn-filter:hover { background:var(--white); color:var(--black); }
.btn-reset { padding:.6rem 1rem; border:1px solid var(--light-gray); background:none; font-family:var(--sans); font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; cursor:pointer; color:#999; transition:all .2s; text-decoration:none; }
.btn-reset:hover { border-color:var(--black); color:var(--black); }

/* Table */
.orders-table { width:100%; border-collapse:collapse; font-size:.85rem; }
.orders-table thead th { padding:.75rem 1rem; font-size:.63rem; letter-spacing:.16em; text-transform:uppercase; color:#999; font-weight:400; border-bottom:2px solid var(--light-gray); text-align:left; white-space:nowrap; }
.orders-table tbody tr { border-bottom:1px solid rgba(235,235,235,.7); transition:background .15s; }
.orders-table tbody tr:hover { background:var(--cream); }
.orders-table tbody td { padding:.85rem 1rem; vertical-align:middle; }

.order-code-link { font-family:monospace; font-size:.85rem; font-weight:600; color:var(--black); text-decoration:none; border-bottom:1px solid var(--light-gray); transition:border-color .2s; }
.order-code-link:hover { border-color:var(--black); }
.customer-name { font-size:.85rem; color:var(--black); }
.customer-phone { font-size:.72rem; color:#999; margin-top:.1rem; }

.status-badge { font-size:.62rem; letter-spacing:.08em; text-transform:uppercase; padding:.28rem .7rem; font-weight:500; white-space:nowrap; }
.payment-badge { font-size:.62rem; letter-spacing:.08em; text-transform:uppercase; padding:.2rem .6rem; }
.payment-paid   { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
.payment-unpaid { background:#fef2f2; color:#c0392b; border:1px solid #fecaca; }

.action-btn { padding:.38rem .8rem; border:1px solid var(--light-gray); background:none; font-family:var(--sans); font-size:.68rem; letter-spacing:.1em; text-transform:uppercase; color:var(--charcoal); text-decoration:none; transition:all .2s; white-space:nowrap; }
.action-btn:hover { border-color:var(--black); color:var(--black); }

/* Pagination */
.pagination { display:flex; justify-content:center; gap:.4rem; margin-top:2rem; }
.page-btn { width:36px; height:36px; display:flex; align-items:center; justify-content:center; border:1px solid var(--light-gray); background:none; font-size:.8rem; color:var(--charcoal); text-decoration:none; transition:all .2s; }
.page-btn:hover, .page-btn.active { background:var(--black); color:var(--white); border-color:var(--black); }

.empty-state { text-align:center; padding:4rem; color:#bbb; }
.empty-state svg { width:48px; height:48px; stroke-width:1; margin:0 auto 1rem; }
@@media (max-width:1024px) { .stats-row { grid-template-columns:repeat(2,1fr); } }
</style>
}

<div class="orders-admin-page">

    <div class="page-header">
        <div>
            <div class="page-eyebrow">Quản Trị Viên</div>
            <h1 class="page-title">Quản Lý <em>Đơn Hàng</em></h1>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fffbeb">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#d97706"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
            </div>
            <div><div class="stat-num">@Model.PendingCount</div><div class="stat-label">Chờ xác nhận</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#eff6ff">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#3b82f6"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div><div class="stat-num">@Model.ConfirmedCount</div><div class="stat-label">Đã xác nhận</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#f0f9ff">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#0ea5e9"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <div><div class="stat-num">@Model.ShippingCount</div><div class="stat-label">Đang giao</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#f0fdf4">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#16a34a"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
            </div>
            <div><div class="stat-num">@Model.DeliveredCount</div><div class="stat-label">Hoàn thành</div></div>
        </div>
    </div>

    <form asp-action="Index" method="get" class="filter-row">
        <div class="filter-group">
            <div class="filter-label">Tìm kiếm</div>
            <div class="search-wrap">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <input type="text" name="search" class="filter-input" placeholder="Mã đơn, tên, SĐT..." value="@Model.Search" />
            </div>
        </div>
        <div class="filter-group">
            <div class="filter-label">Trạng thái</div>
            <select name="status" class="filter-select">
                <option value="">Tất cả</option>
                <option value="0" selected="@(Model.StatusFilter == Project_Essay_Course.Models.OrderStatus.Pending)">Chờ xác nhận</option>
                <option value="1" selected="@(Model.StatusFilter == Project_Essay_Course.Models.OrderStatus.Confirmed)">Đã xác nhận</option>
                <option value="2" selected="@(Model.StatusFilter == Project_Essay_Course.Models.OrderStatus.Processing)">Đang chuẩn bị</option>
                <option value="3" selected="@(Model.StatusFilter == Project_Essay_Course.Models.OrderStatus.Shipping)">Đang giao</option>
                <option value="4" selected="@(Model.StatusFilter == Project_Essay_Course.Models.OrderStatus.Delivered)">Hoàn thành</option>
                <option value="5" selected="@(Model.StatusFilter == Project_Essay_Course.Models.OrderStatus.Cancelled)">Đã hủy</option>
            </select>
        </div>
        <button type="submit" class="btn-filter">Lọc</button>
        <a asp-action="Index" class="btn-reset">Xóa lọc</a>
    </form>

    @if (!Model.Orders.Any())
    {
        <div class="empty-state">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
            <p>Không có đơn hàng nào.</p>
        </div>
    }
    else
    {
        <table class="orders-table">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Sản phẩm</th>
                    <th>Tổng tiền</th>
                    <th>Thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Ngày đặt</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders)
                {
                    <tr>
                        <td>
                            <a asp-action="Detail" asp-route-id="@o.OrderId" class="order-code-link">
                                @o.OrderCode
                            </a>
                        </td>
                        <td>
                            <div class="customer-name">@o.FullName</div>
                            <div class="customer-phone">@o.Phone</div>
                        </td>
                        <td style="font-size:.8rem;color:#888">@o.OrderItems.Count sản phẩm</td>
                        <td style="font-weight:500">@o.TotalAmount.ToString("N0")₫</td>
                        <td>
                            @if (o.PaymentStatus == Project_Essay_Course.Models.PaymentStatus.Paid)
                            { <span class="payment-badge payment-paid">Đã TT</span> }
                            else
                            { <span class="payment-badge payment-unpaid">Chưa TT</span> }
                        </td>
                        <td>
                            <span class="status-badge"
                                  style="background:@(o.StatusColor)1a;color:@o.StatusColor;border:1px solid @(o.StatusColor)40">
                                @o.StatusDisplay
                            </span>
                        </td>
                        <td style="font-size:.78rem;color:#999;white-space:nowrap">
                            @o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                        </td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@o.OrderId" class="action-btn">Xem</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a class="page-btn @(i == Model.CurrentPage ? "active" : "")"
                       asp-action="Index" asp-route-page="@i"
                       asp-route-search="@Model.Search">@i</a>
                }
            </div>
        }
    }

</div>
