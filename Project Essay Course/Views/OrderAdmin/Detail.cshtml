@model Project_Essay_Course.Models.Order
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi Tiết Đơn: " + Model.OrderCode;
}

@section Styles {
<style>
.oad-page { max-width: 1000px; margin: 3rem auto; padding: 0 2rem; }
.form-breadcrumb { display:flex; align-items:center; gap:.6rem; font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:#999; margin-bottom:2rem; }
.form-breadcrumb a { color:#999; text-decoration:none; transition:color .2s; }
.form-breadcrumb a:hover { color:var(--black); }
.form-breadcrumb svg { width:12px; height:12px; stroke-width:2; }

.oad-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:2rem; flex-wrap:wrap; gap:1rem; }
.oad-title { font-family:var(--serif); font-size:clamp(1.4rem,2.5vw,2rem); font-weight:300; }
.oad-title em { font-style:italic; }
.oad-date { font-size:.78rem; color:#999; margin-top:.3rem; }

/* Status update form */
.status-update-card { border:1px solid var(--light-gray); padding:1.4rem 1.6rem; margin-bottom:1.5rem; background:var(--cream); }
.status-update-title { font-size:.68rem; letter-spacing:.18em; text-transform:uppercase; color:var(--accent); margin-bottom:1rem; }
.status-btns { display:flex; gap:.6rem; flex-wrap:wrap; }
.status-btn {
    padding:.55rem 1.2rem; border:1px solid var(--light-gray); background:var(--white);
    font-family:var(--sans); font-size:.72rem; letter-spacing:.1em; text-transform:uppercase;
    cursor:pointer; transition:all .2s; color:var(--charcoal);
}
.status-btn:hover { border-color:var(--black); color:var(--black); }
.status-btn.current { border-color:var(--black); background:var(--black); color:var(--white); cursor:default; }
.status-btn.cancel-btn { color:var(--danger); border-color:rgba(192,57,43,.3); }
.status-btn.cancel-btn:hover { background:var(--danger); color:var(--white); border-color:var(--danger); }

/* Grid */
.oad-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1.5rem; }
.oad-card { border:1px solid var(--light-gray); padding:1.4rem 1.6rem; }
.oad-card-title { font-size:.65rem; letter-spacing:.16em; text-transform:uppercase; color:var(--accent); margin-bottom:1rem; }
.info-row { display:flex; justify-content:space-between; align-items:flex-start; padding:.4rem 0; font-size:.84rem; border-bottom:1px solid rgba(235,235,235,.6); gap:.5rem; }
.info-row:last-child { border-bottom:none; }
.info-label { color:#999; flex-shrink:0; }
.info-value { font-weight:500; text-align:right; }

/* Items */
.oad-items { border:1px solid var(--light-gray); margin-bottom:1.5rem; }
.oad-items-head { display:grid; grid-template-columns:1fr 100px 60px 100px; gap:.5rem; padding:.6rem 1.2rem; background:#f9f9f8; font-size:.62rem; letter-spacing:.14em; text-transform:uppercase; color:#aaa; }
.oad-item { display:grid; grid-template-columns:1fr 100px 60px 100px; gap:.5rem; padding:.9rem 1.2rem; border-top:1px solid rgba(235,235,235,.6); align-items:center; }
.oad-item-name { font-size:.88rem; }
.oad-item-variants { display:flex; flex-wrap:wrap; gap:.3rem; margin-top:.35rem; }
.oad-variant-tag { font-size:.65rem; letter-spacing:.06em; padding:.18rem .55rem; border:1px solid var(--light-gray); background:var(--cream); color:var(--charcoal); }
.oad-item-sku { font-size:.65rem; color:#bbb; margin-top:.25rem; font-family:monospace; }

/* Totals */
.oad-totals { border:1px solid var(--light-gray); padding:1.2rem 1.4rem; margin-bottom:1.5rem; }
.total-row { display:flex; justify-content:space-between; padding:.4rem 0; font-size:.88rem; }
.total-final { border-top:2px solid var(--black); margin-top:.6rem; padding-top:.8rem; font-family:var(--serif); }

.payment-paid   { font-size:.62rem; padding:.2rem .6rem; background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
.payment-unpaid { font-size:.62rem; padding:.2rem .6rem; background:#fef2f2; color:#c0392b; border:1px solid #fecaca; }

@@media (max-width:640px) { .oad-grid { grid-template-columns:1fr; } .oad-items-head, .oad-item { grid-template-columns:1fr auto; } }
</style>
}

<div class="oad-page">

    <div class="form-breadcrumb">
        <a asp-action="Index">Đơn hàng</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>@Model.OrderCode</span>
    </div>

    <div class="oad-header">
        <div>
            <h1 class="oad-title">Đơn <em>#@Model.OrderCode</em></h1>
            <div class="oad-date">Đặt lúc @Model.CreatedAt.ToLocalTime().ToString("HH:mm — dd/MM/yyyy")</div>
        </div>
        <span style="font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;padding:.4rem 1rem;font-weight:500;color:@Model.StatusColor;background:@(Model.StatusColor)1a;border:1px solid @(Model.StatusColor)40">
            @Model.StatusDisplay
        </span>
    </div>

    <div class="status-update-card">
        <div class="status-update-title">Cập Nhật Trạng Thái</div>
        <div class="status-btns">
            @{
                var statuses = new[] {
                    (Project_Essay_Course.Models.OrderStatus.Pending,    "Chờ xác nhận"),
                    (Project_Essay_Course.Models.OrderStatus.Confirmed,  "Đã xác nhận"),
                    (Project_Essay_Course.Models.OrderStatus.Processing, "Chuẩn bị hàng"),
                    (Project_Essay_Course.Models.OrderStatus.Shipping,   "Đang giao"),
                    (Project_Essay_Course.Models.OrderStatus.Delivered,  "Hoàn thành"),
                };
            }
            @foreach (var (s, label) in statuses)
            {
                if (Model.Status == s)
                {
                    <button class="status-btn current" disabled>@label</button>
                }
                else
                {
                    <form asp-action="UpdateStatus" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId"   value="@Model.OrderId" />
                        <input type="hidden" name="newStatus" value="@((int)s)" />
                        <button type="submit" class="status-btn">@label</button>
                    </form>
                }
            }

            @if (Model.Status != Project_Essay_Course.Models.OrderStatus.Cancelled)
            {
                <form asp-action="UpdateStatus" method="post" style="display:inline"
                      onsubmit="return confirm('Hủy đơn hàng này?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId"   value="@Model.OrderId" />
                    <input type="hidden" name="newStatus" value="5" />
                    <button type="submit" class="status-btn cancel-btn">Hủy đơn</button>
                </form>
            }
        </div>
    </div>

    <div class="oad-grid">
        <div class="oad-card">
            <div class="oad-card-title">Thông Tin Nhận Hàng</div>
            <div class="info-row"><span class="info-label">Họ tên</span><span class="info-value">@Model.FullName</span></div>
            <div class="info-row"><span class="info-label">SĐT</span><span class="info-value">@Model.Phone</span></div>
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <div class="info-row"><span class="info-label">Email</span><span class="info-value">@Model.Email</span></div>
            }
            <div class="info-row"><span class="info-label">Địa chỉ</span><span class="info-value" style="text-align:right">@Model.Address, @Model.Ward, @Model.District, @Model.Province</span></div>
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div class="info-row"><span class="info-label">Ghi chú</span><span class="info-value">@Model.Note</span></div>
            }
        </div>
        <div class="oad-card">
            <div class="oad-card-title">Thanh Toán</div>
            <div class="info-row"><span class="info-label">Phương thức</span><span class="info-value">@Model.PaymentMethodDisplay</span></div>
            <div class="info-row">
                <span class="info-label">Trạng thái</span>
                <span class="info-value">
                    @if (Model.PaymentStatus == Project_Essay_Course.Models.PaymentStatus.Paid)
                    { <span class="payment-paid">Đã thanh toán</span> }
                    else
                    { <span class="payment-unpaid">Chưa thanh toán</span> }
                </span>
            </div>
            @if (Model.PaidAt.HasValue)
            {
                <div class="info-row"><span class="info-label">Thời gian TT</span><span class="info-value">@Model.PaidAt.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</span></div>
            }
            <div class="info-row"><span class="info-label">Tổng tiền</span><span class="info-value" style="font-size:1rem;color:var(--black)">@Model.TotalAmount.ToString("N0")₫</span></div>
        </div>
    </div>

    <div class="oad-items">
        <div class="oad-items-head">
            <span>Sản phẩm</span>
            <span style="text-align:center">Đơn giá</span>
            <span style="text-align:center">SL</span>
            <span style="text-align:right">Thành tiền</span>
        </div>
        @foreach (var item in Model.OrderItems)
        {
            <div class="oad-item">
                <div>
                    <div class="oad-item-name">@item.ProductName</div>
                    @if (!string.IsNullOrEmpty(item.VariantDisplay) && item.VariantDisplay != "Mặc định")
                    {
                        <div class="oad-item-variants">
                            @foreach (var part in item.VariantDisplay.Split(" / "))
                            { <span class="oad-variant-tag">@part.Trim()</span> }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(item.SKU))
                    { <div class="oad-item-sku">SKU: @item.SKU</div> }
                </div>
                <div style="text-align:center;font-size:.84rem">@item.UnitPrice.ToString("N0")₫</div>
                <div style="text-align:center;font-size:.84rem">@item.Quantity</div>
                <div style="text-align:right;font-weight:500;font-size:.84rem">@item.SubTotal.ToString("N0")₫</div>
            </div>
        }
    </div>

    <div class="oad-totals">
        <div class="total-row"><span>Tạm tính</span><span>@Model.SubTotal.ToString("N0")₫</span></div>
        <div class="total-row"><span>Phí vận chuyển</span><span>@(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("N0") + "₫")</span></div>
        <div class="total-row total-final"><span>Tổng cộng</span><span style="font-size:1.1rem;font-weight:600">@Model.TotalAmount.ToString("N0")₫</span></div>
    </div>

    <div class="status-update-card" style="margin-top:1rem">
        <div class="status-update-title">Cập Nhật Thanh Toán</div>
        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
            <span style="font-size:.84rem;color:var(--charcoal)">Trạng thái hiện tại:</span>
            @if (Model.PaymentStatus == Project_Essay_Course.Models.PaymentStatus.Paid)
            {
                <span class="payment-paid">✓ Đã thanh toán</span>
                @if (Model.PaidAt.HasValue)
                { <span style="font-size:.75rem;color:#999">— @Model.PaidAt.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</span> }
                <form asp-action="UpdatePaymentStatus" method="post" style="display:inline"
                      onsubmit="return confirm('Đánh dấu lại là chưa thanh toán?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <input type="hidden" name="isPaid"  value="false" />
                    <button type="submit" class="status-btn" style="font-size:.7rem;padding:.42rem .9rem">Đánh dấu chưa TT</button>
                </form>
            }
            else
            {
                <span class="payment-unpaid">✗ Chưa thanh toán</span>
                <form asp-action="UpdatePaymentStatus" method="post" style="display:inline"
                      onsubmit="return confirm('Xác nhận đã nhận được tiền?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <input type="hidden" name="isPaid"  value="true" />
                    <button type="submit" class="status-btn" style="font-size:.7rem;padding:.42rem .9rem;color:#15803d;border-color:#86efac">
                        ✓ Xác nhận đã TT
                    </button>
                </form>
            }
        </div>
    </div>

    <div style="display:flex;gap:.8rem;margin-top:1.5rem;flex-wrap:wrap">
        <a asp-action="Index" style="padding:.8rem 1.8rem;border:1px solid var(--light-gray);background:none;font-family:var(--sans);font-size:.74rem;letter-spacing:.12em;text-transform:uppercase;color:var(--charcoal);text-decoration:none;transition:all .2s">
            ← Danh sách đơn
        </a>
        <a asp-action="Invoice" asp-route-id="@Model.OrderId" target="_blank"
           style="padding:.8rem 1.8rem;border:1px solid var(--accent);background:none;font-family:var(--sans);font-size:.74rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:.4rem">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:14px;height:14px;stroke-width:2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Xuất hóa đơn
        </a>
    </div>

</div>
