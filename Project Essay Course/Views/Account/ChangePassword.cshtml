@model Project_Essay_Course.ViewModels.Account_ViewModel.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi Mật Khẩu";
}

@section Styles {
<style>
.changepwd-page {
    max-width: 560px;
    margin: 3rem auto;
    padding: 0 2rem;
}
.edit-breadcrumb {
    display: flex; align-items: center; gap: .6rem;
    font-size: .72rem; letter-spacing: .12em; text-transform: uppercase;
    color: #999; margin-bottom: 2.5rem;
}
.edit-breadcrumb a { color: #999; text-decoration: none; transition: color .2s; }
.edit-breadcrumb a:hover { color: var(--black); }
.edit-breadcrumb svg { width: 12px; height: 12px; stroke-width: 2; }
.edit-eyebrow { font-size: .68rem; letter-spacing: .22em; text-transform: uppercase; color: var(--accent); margin-bottom: .6rem; }
.edit-title { font-family: var(--serif); font-size: clamp(1.6rem,3vw,2.4rem); font-weight: 300; color: var(--black); margin-bottom: 2.5rem; }
.edit-title em { font-style: italic; }

.pwd-card { border: 1px solid var(--light-gray); padding: 2.5rem; }

.field-group { margin-bottom: 1.6rem; }
.field-label { display: block; font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; color: var(--charcoal); margin-bottom: .5rem; }
.field-input {
    width: 100%; padding: .85rem 1rem;
    border: 1px solid var(--light-gray); background: var(--white);
    font-family: var(--sans); font-size: .9rem; color: var(--black);
    outline: none; transition: border-color var(--transition);
}
.field-input:focus { border-color: var(--black); }
.field-error { font-size: .72rem; color: var(--danger); margin-top: .4rem; display: block; }
.field-hint  { font-size: .72rem; color: #999; margin-top: .4rem; line-height: 1.5; }
.field-input-wrap { position: relative; }
.eye-btn {
    position: absolute; right: .9rem; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: #999; display: flex; padding: 0; transition: color .2s;
}
.eye-btn:hover { color: var(--black); }
.eye-btn svg { width: 18px; height: 18px; stroke-width: 1.4; }

.field-divider { height: 1px; background: var(--light-gray); margin: 2rem 0; }

/* Strength meter */
.pwd-strength { margin-top: .6rem; }
.pwd-strength-bar { height: 3px; background: var(--light-gray); overflow: hidden; margin-bottom: .35rem; }
.pwd-strength-fill { height: 100%; width: 0%; transition: width .35s, background .35s; }
.pwd-strength-label { font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: #999; }

/* Match indicator */
.match-indicator {
    display: flex; align-items: center; gap: .4rem;
    font-size: .72rem; margin-top: .4rem;
}
.match-indicator svg { width: 14px; height: 14px; stroke-width: 2; }
.match-ok   { color: #16a34a; }
.match-fail { color: var(--danger); }
.match-idle { color: #bbb; }

.val-summary {
    background: #fef2f2; border-left: 3px solid var(--danger);
    padding: .9rem 1rem; margin-bottom: 1.6rem;
    font-size: .82rem; color: var(--danger);
}
.val-summary ul { padding-left: 1.2rem; margin: 0; }

.form-actions { display: flex; gap: 1rem; align-items: center; padding-top: 2rem; border-top: 1px solid var(--light-gray); }
.btn-save {
    padding: .9rem 2.5rem; background: var(--black); color: var(--white);
    border: 1px solid var(--black); font-family: var(--sans); font-size: .78rem;
    font-weight: 400; letter-spacing: .16em; text-transform: uppercase;
    cursor: pointer; transition: background var(--transition), color var(--transition);
}
.btn-save:hover { background: var(--white); color: var(--black); }
.btn-cancel {
    padding: .9rem 2rem; background: none; color: var(--charcoal);
    border: 1px solid var(--light-gray); font-family: var(--sans); font-size: .78rem;
    letter-spacing: .16em; text-transform: uppercase; text-decoration: none;
    cursor: pointer; transition: border-color .25s, color .25s;
}
.btn-cancel:hover { border-color: var(--black); color: var(--black); }

/* Tips */
.pwd-tips {
    margin-top: 1.4rem; padding: 1.2rem 1.4rem;
    background: var(--cream); border-left: 3px solid var(--stone);
}
.pwd-tips-title { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; color: var(--charcoal); margin-bottom: .8rem; }
.pwd-tips ul { padding-left: 1.2rem; margin: 0; }
.pwd-tips li { font-size: .78rem; color: #777; line-height: 1.7; }

@@media (max-width: 500px) {
    .form-actions { flex-direction: column; align-items: stretch; }
    .btn-save, .btn-cancel { text-align: center; }
}
</style>
}

<div class="changepwd-page">

    <div class="edit-breadcrumb">
        <a asp-action="Profile">Hồ sơ</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>Đổi mật khẩu</span>
    </div>

    <div class="edit-eyebrow">Bảo mật</div>
    <h1 class="edit-title">Đổi <em>Mật Khẩu</em></h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="val-summary">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="pwd-card">
        <form asp-action="ChangePassword" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="field-group">
                <label class="field-label" asp-for="CurrentPassword">Mật khẩu hiện tại</label>
                <div class="field-input-wrap">
                    <input asp-for="CurrentPassword" type="password" class="field-input"
                           id="cur-pwd" placeholder="••••••••" autocomplete="current-password" />
                    <button type="button" class="eye-btn" onclick="togglePwd('cur-pwd')">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="field-error"></span>
            </div>

            <div class="field-divider"></div>

            <div class="field-group">
                <label class="field-label" asp-for="NewPassword">Mật khẩu mới</label>
                <div class="field-input-wrap">
                    <input asp-for="NewPassword" type="password" class="field-input"
                           id="new-pwd" placeholder="Tối thiểu 6 ký tự"
                           autocomplete="new-password" />
                    <button type="button" class="eye-btn" onclick="togglePwd('new-pwd')">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="pwd-strength">
                    <div class="pwd-strength-bar">
                        <div class="pwd-strength-fill" id="pwd-fill"></div>
                    </div>
                    <div class="pwd-strength-label" id="pwd-label">Nhập mật khẩu mới</div>
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                <div class="field-input-wrap">
                    <input asp-for="ConfirmPassword" type="password" class="field-input"
                           id="con-pwd" placeholder="Nhập lại mật khẩu mới"
                           autocomplete="new-password" />
                    <button type="button" class="eye-btn" onclick="togglePwd('con-pwd')">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="match-indicator match-idle" id="match-indicator">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
                    </svg>
                    <span id="match-text">Nhập xác nhận mật khẩu</span>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">Cập Nhật Mật Khẩu</button>
                <a asp-action="Profile" class="btn-cancel">Hủy</a>
            </div>
        </form>
    </div>

    <div class="pwd-tips">
        <div class="pwd-tips-title">💡 Gợi ý mật khẩu mạnh</div>
        <ul>
            <li>Ít nhất 8 ký tự trở lên</li>
            <li>Kết hợp chữ hoa và chữ thường</li>
            <li>Có ít nhất một chữ số (0–9)</li>
            <li>Thêm ký tự đặc biệt (!@@#$%)</li>
            <li>Không dùng thông tin cá nhân (ngày sinh, tên)</li>
        </ul>
    </div>

</div>

@section Scripts {
<script>
function togglePwd(id) {
    const el = document.getElementById(id);
    el.type = el.type === 'text' ? 'password' : 'text';
}

// Strength meter
document.getElementById('new-pwd').addEventListener('input', function () {
    const val = this.value;
    let score = 0;
    if (val.length >= 6)  score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const levels = [
        { pct:'0%',   color:'transparent', text:'Nhập mật khẩu mới' },
        { pct:'25%',  color:'#e74c3c',      text:'Yếu' },
        { pct:'50%',  color:'#e67e22',      text:'Trung bình' },
        { pct:'75%',  color:'#f1c40f',      text:'Khá mạnh' },
        { pct:'100%', color:'#27ae60',      text:'Rất mạnh' },
    ];
    const lv = levels[Math.min(score, 4)];
    document.getElementById('pwd-fill').style.width      = lv.pct;
    document.getElementById('pwd-fill').style.background = lv.color;
    const label = document.getElementById('pwd-label');
    label.textContent  = lv.text;
    label.style.color  = lv.color === 'transparent' ? '#999' : lv.color;
    checkMatch();
});

// Match check
document.getElementById('con-pwd').addEventListener('input', checkMatch);

function checkMatch() {
    const a = document.getElementById('new-pwd').value;
    const b = document.getElementById('con-pwd').value;
    const ind  = document.getElementById('match-indicator');
    const text = document.getElementById('match-text');
    if (!b) {
        ind.className = 'match-indicator match-idle';
        ind.querySelector('svg').innerHTML = '<circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>';
        text.textContent = 'Nhập xác nhận mật khẩu';
    } else if (a === b) {
        ind.className = 'match-indicator match-ok';
        ind.querySelector('svg').innerHTML = '<path d="M20 6 9 17l-5-5"/>';
        text.textContent = 'Mật khẩu khớp';
    } else {
        ind.className = 'match-indicator match-fail';
        ind.querySelector('svg').innerHTML = '<path d="M18 6 6 18M6 6l12 12"/>';
        text.textContent = 'Mật khẩu chưa khớp';
    }
}
</script>
}
