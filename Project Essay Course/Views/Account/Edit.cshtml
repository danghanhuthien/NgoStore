@model Project_Essay_Course.ViewModels.Account_ViewModel.EditProfileViewModel
@{
    ViewData["Title"] = "Chỉnh Sửa Hồ Sơ";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

@section Styles {
<style>
.edit-page {
    max-width: 760px;
    margin: 3rem auto;
    padding: 0 2rem;
}

.edit-breadcrumb {
    display: flex; align-items: center; gap: .6rem;
    font-size: .72rem; letter-spacing: .12em; text-transform: uppercase;
    color: #999; margin-bottom: 2.5rem;
}
.edit-breadcrumb a { color: #999; text-decoration: none; transition: color .2s; }
.edit-breadcrumb a:hover { color: var(--black); }
.edit-breadcrumb svg { width: 12px; height: 12px; stroke-width: 2; }

.edit-header { margin-bottom: 2.5rem; }
.edit-eyebrow { font-size: .68rem; letter-spacing: .22em; text-transform: uppercase; color: var(--accent); margin-bottom: .6rem; }
.edit-title { font-family: var(--serif); font-size: clamp(1.6rem,3vw,2.4rem); font-weight: 300; color: var(--black); }
.edit-title em { font-style: italic; }

.edit-card {
    border: 1px solid var(--light-gray);
    padding: 2.5rem;
    margin-bottom: 1.4rem;
}
.edit-card-title {
    font-size: .7rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 2rem;
    padding-bottom: .9rem; border-bottom: 1px solid var(--light-gray);
}

/* Fields */
.field-group { margin-bottom: 1.6rem; }
.field-label {
    display: block; font-size: .7rem; letter-spacing: .14em;
    text-transform: uppercase; color: var(--charcoal); margin-bottom: .5rem;
}
.field-label .required { color: var(--danger); margin-left: .2rem; }
.field-input {
    width: 100%; padding: .85rem 1rem;
    border: 1px solid var(--light-gray); background: var(--white);
    font-family: var(--sans); font-size: .9rem; color: var(--black);
    outline: none; transition: border-color var(--transition);
}
.field-input:focus   { border-color: var(--black); }
.field-input:disabled { background: var(--cream); color: #999; cursor: not-allowed; }
.field-error  { font-size: .72rem; color: var(--danger); margin-top: .4rem; display: block; }
.field-hint   { font-size: .72rem; color: #999; margin-top: .4rem; line-height: 1.5; }

.field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }

/* Read-only pill */
.readonly-pill {
    display: inline-flex; align-items: center; gap: .4rem;
    font-size: .68rem; letter-spacing: .1em; text-transform: uppercase;
    color: #999; background: var(--cream); padding: .2rem .7rem;
    margin-left: .6rem; vertical-align: middle;
}

/* Form actions */
.form-actions {
    display: flex; gap: 1rem; align-items: center;
    padding-top: 2rem; border-top: 1px solid var(--light-gray);
}
.btn-save {
    padding: .9rem 2.5rem;
    background: var(--black); color: var(--white);
    border: 1px solid var(--black);
    font-family: var(--sans); font-size: .78rem;
    font-weight: 400; letter-spacing: .16em; text-transform: uppercase;
    cursor: pointer; transition: background var(--transition), color var(--transition);
}
.btn-save:hover { background: var(--white); color: var(--black); }

.btn-cancel {
    padding: .9rem 2rem;
    background: none; color: var(--charcoal);
    border: 1px solid var(--light-gray);
    font-family: var(--sans); font-size: .78rem;
    letter-spacing: .16em; text-transform: uppercase;
    text-decoration: none; cursor: pointer;
    transition: border-color .25s, color .25s;
}
.btn-cancel:hover { border-color: var(--black); color: var(--black); }

.val-summary {
    background: #fef2f2; border-left: 3px solid var(--danger);
    padding: .9rem 1rem; margin-bottom: 1.4rem;
    font-size: .82rem; color: var(--danger);
}
.val-summary ul { padding-left: 1.2rem; margin: 0; }

@@media (max-width: 600px) {
    .field-grid { grid-template-columns: 1fr; }
    .form-actions { flex-direction: column; align-items: stretch; }
    .btn-save, .btn-cancel { text-align: center; }
}
</style>
}

<div class="edit-page">

    <!-- Breadcrumb -->
    <div class="edit-breadcrumb">
        <a asp-action="Profile">Hồ sơ</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>Chỉnh sửa</span>
    </div>

    <!-- Header -->
    <div class="edit-header">
        <div class="edit-eyebrow">Tài khoản</div>
        <h1 class="edit-title">Chỉnh Sửa <em>Hồ Sơ</em></h1>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="val-summary">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Edit" method="post" novalidate>
        @Html.AntiForgeryToken()

        <!-- Thông tin cơ bản -->
        <div class="edit-card">
            <div class="edit-card-title">Thông Tin Cơ Bản</div>

            <div class="field-group">
                <label class="field-label">
                    Email
                    <span class="readonly-pill">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:10px;height:10px;stroke-width:2">
                            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        Không thể thay đổi
                    </span>
                </label>
                <input asp-for="Email" type="email" class="field-input"
                       disabled value="@Model.Email" />
                <span class="field-hint">Email được dùng để đăng nhập, liên hệ quản trị viên nếu cần thay đổi.</span>
            </div>

            <div class="field-group">
                <label class="field-label">
                    Tên tài khoản
                    <span class="readonly-pill">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:10px;height:10px;stroke-width:2">
                            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        Không thể thay đổi
                    </span>
                </label>
                <input asp-for="UserName" type="text" class="field-input" disabled value="@Model.UserName" />
            </div>
        </div>

        <!-- Thông tin liên hệ -->
        <div class="edit-card">
            <div class="edit-card-title">Thông Tin Liên Hệ</div>

            <div class="field-group">
                <label class="field-label" asp-for="PhoneNumber">
                    Số điện thoại
                </label>
                <input asp-for="PhoneNumber" type="tel" class="field-input"
                       placeholder="VD: 0901 234 567" autocomplete="tel" />
                <span asp-validation-for="PhoneNumber" class="field-error"></span>
                <span class="field-hint">Dùng để nhận thông báo đơn hàng qua SMS.</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="form-actions">
            <button type="submit" class="btn-save">Lưu Thay Đổi</button>
            <a asp-action="Profile" class="btn-cancel">Hủy</a>
        </div>

    </form>
</div>
