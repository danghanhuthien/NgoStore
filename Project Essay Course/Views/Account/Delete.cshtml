@model Project_Essay_Course.ViewModels.Account_ViewModel.DeleteAccountViewModel
@{
    ViewData["Title"] = "Xóa Tài Khoản";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

@section Styles {
<style>
.delete-page {
    max-width: 560px;
    margin: 3rem auto;
    padding: 0 2rem;
}
.edit-breadcrumb {
    display: flex; align-items: center; gap: .6rem;
    font-size: .72rem; letter-spacing: .12em; text-transform: uppercase;
    color: #999; margin-bottom: 2.5rem;
}
.edit-breadcrumb a { color: #999; text-decoration: none; transition: color .2s; }
.edit-breadcrumb a:hover { color: var(--black); }
.edit-breadcrumb svg { width: 12px; height: 12px; stroke-width: 2; }

.delete-header { margin-bottom: 2rem; }
.delete-eyebrow { font-size: .68rem; letter-spacing: .22em; text-transform: uppercase; color: var(--danger); margin-bottom: .6rem; }
.delete-title { font-family: var(--serif); font-size: clamp(1.6rem,3vw,2.4rem); font-weight: 300; color: var(--black); }
.delete-title em { font-style: italic; color: var(--danger); }

/* Warning banner */
.warning-banner {
    display: flex; gap: 1rem; align-items: flex-start;
    padding: 1.2rem 1.4rem;
    background: #fff5f5;
    border: 1px solid rgba(192,57,43,.25);
    border-left: 4px solid var(--danger);
    margin-bottom: 2rem;
}
.warning-icon {
    width: 36px; height: 36px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(192,57,43,.1); border-radius: 50%;
    color: var(--danger);
}
.warning-icon svg { width: 18px; height: 18px; stroke-width: 2; }
.warning-text { font-size: .82rem; color: #8b2c2c; line-height: 1.65; }
.warning-text strong { display: block; font-size: .86rem; margin-bottom: .3rem; }

/* Consequences list */
.consequences {
    background: var(--cream); padding: 1.4rem;
    margin-bottom: 2rem; border: 1px solid var(--stone);
}
.consequences-title { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; color: var(--charcoal); margin-bottom: .9rem; }
.consequences ul { padding-left: 0; margin: 0; list-style: none; display: flex; flex-direction: column; gap: .55rem; }
.consequences li {
    display: flex; gap: .6rem; align-items: flex-start;
    font-size: .82rem; color: var(--charcoal); line-height: 1.5;
}
.consequences li::before { content: '✕'; color: var(--danger); font-size: .8rem; margin-top: .05rem; flex-shrink: 0; }

/* Form */
.delete-card { border: 1px solid rgba(192,57,43,.3); padding: 2rem 2.5rem; }
.delete-card-title { font-size: .7rem; letter-spacing: .2em; text-transform: uppercase; color: var(--danger); margin-bottom: 1.6rem; }

.field-group { margin-bottom: 1.4rem; }
.field-label { display: block; font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; color: var(--charcoal); margin-bottom: .5rem; }
.field-input {
    width: 100%; padding: .85rem 1rem;
    border: 1px solid var(--light-gray); background: var(--white);
    font-family: var(--sans); font-size: .9rem; color: var(--black);
    outline: none; transition: border-color var(--transition);
}
.field-input:focus { border-color: var(--danger); }
.field-error  { font-size: .72rem; color: var(--danger); margin-top: .4rem; display: block; }
.field-input-wrap { position: relative; }
.eye-btn {
    position: absolute; right: .9rem; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: #999; display: flex; padding: 0; transition: color .2s;
}
.eye-btn:hover { color: var(--black); }
.eye-btn svg { width: 18px; height: 18px; stroke-width: 1.4; }

.confirm-text {
    font-size: .82rem; color: #888; margin-bottom: 1.4rem; line-height: 1.6;
    padding: 1rem; background: rgba(192,57,43,.04);
    border: 1px dashed rgba(192,57,43,.3);
}
.confirm-text strong { color: var(--danger); }

.val-summary { background: #fef2f2; border-left: 3px solid var(--danger); padding: .9rem 1rem; margin-bottom: 1.4rem; font-size: .82rem; color: var(--danger); }
.val-summary ul { padding-left: 1.2rem; margin: 0; }

.form-actions { display: flex; gap: 1rem; align-items: center; padding-top: 1.6rem; border-top: 1px solid rgba(192,57,43,.2); }
.btn-delete-confirm {
    padding: .9rem 2rem; background: var(--danger); color: var(--white);
    border: 1px solid var(--danger); font-family: var(--sans); font-size: .78rem;
    font-weight: 400; letter-spacing: .16em; text-transform: uppercase;
    cursor: pointer; transition: background .25s, opacity .25s;
    opacity: .6; pointer-events: none;
}
.btn-delete-confirm.enabled { opacity: 1; pointer-events: all; }
.btn-delete-confirm.enabled:hover { background: #a93226; border-color: #a93226; }
.btn-cancel {
    padding: .9rem 2rem; background: none; color: var(--charcoal);
    border: 1px solid var(--light-gray); font-family: var(--sans); font-size: .78rem;
    letter-spacing: .16em; text-transform: uppercase; text-decoration: none;
    cursor: pointer; transition: border-color .25s, color .25s;
}
.btn-cancel:hover { border-color: var(--black); color: var(--black); }

@@media (max-width: 500px) {
    .form-actions { flex-direction: column; align-items: stretch; }
    .btn-delete-confirm, .btn-cancel { text-align: center; }
}
</style>
}

<div class="delete-page">

    <div class="edit-breadcrumb">
        <a asp-action="Profile">Hồ sơ</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>Xóa tài khoản</span>
    </div>

    <div class="delete-header">
        <div class="delete-eyebrow">⚠ Vùng nguy hiểm</div>
        <h1 class="delete-title">Xóa <em>Tài Khoản</em></h1>
    </div>

    <!-- Warning -->
    <div class="warning-banner">
        <div class="warning-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <div class="warning-text">
            <strong>Hành động này không thể hoàn tác!</strong>
            Một khi xác nhận, tài khoản và toàn bộ dữ liệu của bạn sẽ bị xóa vĩnh viễn khỏi hệ thống NGỘ STORE.
        </div>
    </div>

    <!-- Consequences -->
    <div class="consequences">
        <div class="consequences-title">Dữ liệu sẽ bị mất</div>
        <ul>
            <li>Thông tin tài khoản và hồ sơ cá nhân</li>
            <li>Toàn bộ lịch sử đơn hàng</li>
            <li>Danh sách sản phẩm yêu thích</li>
            <li>Điểm thưởng và ưu đãi thành viên</li>
            <li>Giỏ hàng đang lưu</li>
        </ul>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="val-summary">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="delete-card">
        <div class="delete-card-title">Xác Nhận Danh Tính</div>

        <div class="confirm-text">
            Bạn đang xóa tài khoản: <strong>@Model.Email</strong>
        </div>

        <form asp-action="Delete" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="Email" type="hidden" />

            <div class="field-group">
                <label class="field-label" asp-for="Password">Nhập mật khẩu để xác nhận</label>
                <div class="field-input-wrap">
                    <input asp-for="Password" type="password" class="field-input"
                           id="del-pwd" placeholder="••••••••"
                           autocomplete="current-password"
                           oninput="checkReady()" />
                    <button type="button" class="eye-btn" onclick="togglePwd()">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-delete-confirm" id="btn-delete">
                    Xóa Vĩnh Viễn
                </button>
                <a asp-action="Profile" class="btn-cancel">Hủy — Giữ Tài Khoản</a>
            </div>
        </form>
    </div>

</div>

@section Scripts {
<script>
function togglePwd() {
    const el = document.getElementById('del-pwd');
    el.type = el.type === 'text' ? 'password' : 'text';
}
function checkReady() {
    const btn = document.getElementById('btn-delete');
    const val = document.getElementById('del-pwd').value;
    btn.classList.toggle('enabled', val.length >= 1);
}
</script>
}
