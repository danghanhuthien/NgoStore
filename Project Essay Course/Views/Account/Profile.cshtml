@model Project_Essay_Course.ViewModels.Account_ViewModel.ProfileViewModel
@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

@section Styles {
<style>
.profile-page {
    max-width: 1100px;
    margin: 3rem auto;
    padding: 0 2rem;
}

/* ── Page header ── */
.profile-page-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--light-gray);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
}
.profile-page-header-left { display: flex; align-items: center; gap: 1.5rem; }

.profile-avatar-large {
    width: 72px; height: 72px; border-radius: 50%;
    background: var(--black);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif); font-size: 2rem;
    font-weight: 600; color: var(--white);
    flex-shrink: 0;
}
.profile-page-name {
    font-family: var(--serif);
    font-size: 1.6rem; font-weight: 300;
}
.profile-page-name em { font-style: italic; }
.profile-page-role {
    font-size: .72rem; letter-spacing: .16em;
    text-transform: uppercase; color: var(--accent);
    margin-top: .2rem;
}

.btn-edit-profile {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .7rem 1.6rem;
    border: 1px solid var(--black); background: none;
    font-family: var(--sans); font-size: .74rem;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--black); text-decoration: none;
    transition: background var(--transition), color var(--transition);
}
.btn-edit-profile:hover { background: var(--black); color: var(--white); }

/* ── Grid layout ── */
.profile-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
}

/* ── Card ── */
.profile-card {
    border: 1px solid var(--light-gray);
    padding: 2rem 2.5rem;
    background: var(--white);
}
.profile-card-title {
    font-size: .7rem; letter-spacing: .2em;
    text-transform: uppercase; color: var(--accent);
    margin-bottom: 1.6rem; padding-bottom: .9rem;
    border-bottom: 1px solid var(--light-gray);
    display: flex; align-items: center; gap: .6rem;
}
.profile-card-title svg { width: 14px; height: 14px; stroke-width: 1.6; }

/* ── Info rows ── */
.info-row {
    display: flex; align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(235,235,235,.6);
}
.info-row:last-child { border-bottom: none; }

.info-label {
    font-size: .72rem; letter-spacing: .12em;
    text-transform: uppercase; color: #999;
    width: 140px; flex-shrink: 0;
}
.info-value {
    font-size: .9rem; color: var(--black); flex: 1;
}
.info-value.empty { color: #bbb; font-style: italic; }

.info-badge {
    font-size: .62rem; letter-spacing: .1em;
    text-transform: uppercase; padding: .25rem .65rem;
    border: 1px solid;
}
.badge-verified  { color: #16a34a; border-color: #16a34a; background: #f0fdf4; }
.badge-unverified { color: #999;  border-color: #ddd;    background: #f9f9f9; }

/* ── Side cards ── */
.quick-action {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(235,235,235,.6);
    text-decoration: none; color: var(--charcoal);
    transition: color .2s;
}
.quick-action:last-child { border-bottom: none; }
.quick-action:hover { color: var(--black); }
.quick-action:hover .qa-arrow { transform: translateX(4px); }

.qa-icon {
    width: 36px; height: 36px;
    background: var(--cream);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.qa-icon svg { width: 16px; height: 16px; stroke-width: 1.5; color: var(--charcoal); }
.qa-text   { flex: 1; }
.qa-title  { font-size: .85rem; font-weight: 400; }
.qa-desc   { font-size: .72rem; color: #999; margin-top: .15rem; }
.qa-arrow  { color: #ccc; transition: transform .2s; }
.qa-arrow svg { width: 14px; height: 14px; stroke-width: 2; }

/* ── Danger zone ── */
.danger-zone {
    margin-top: 2rem;
    padding: 1.5rem 2rem;
    border: 1px solid rgba(192,57,43,.25);
    background: #fff9f8;
}
.danger-zone-title {
    font-size: .7rem; letter-spacing: .18em;
    text-transform: uppercase; color: var(--danger);
    margin-bottom: .7rem;
}
.danger-zone-desc {
    font-size: .82rem; color: #888; margin-bottom: 1.2rem; line-height: 1.55;
}
.btn-danger {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .65rem 1.4rem;
    border: 1px solid var(--danger); background: none;
    font-family: var(--sans); font-size: .72rem;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--danger); text-decoration: none;
    transition: background .25s, color .25s;
}
.btn-danger:hover { background: var(--danger); color: var(--white); }

@@media (max-width: 768px) {
    .profile-grid { grid-template-columns: 1fr; }
    .profile-page-header { flex-direction: column; align-items: flex-start; }
    .info-label { width: 110px; }
}
</style>
}

<div class="profile-page">

    <!-- Page header -->
    <div class="profile-page-header">
        <div class="profile-page-header-left">
            <div class="profile-avatar-large">
                @Model.UserName?.Substring(0, 1).ToUpper()
            </div>
            <div>
                <div class="profile-page-name"><em>@Model.UserName</em></div>
                <div class="profile-page-role">Thành viên MAISON</div>
            </div>
        </div>
        <a asp-action="Edit" class="btn-edit-profile">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:14px;height:14px;stroke-width:1.8">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Chỉnh Sửa
        </a>
    </div>

    <div class="profile-grid">

        <!-- Left: Info card -->
        <div>
            <div class="profile-card">
                <div class="profile-card-title">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    Thông Tin Cá Nhân
                </div>

                <div class="info-row">
                    <div class="info-label">Email</div>
                    <div class="info-value">@Model.Email</div>
                    <span class="info-badge badge-verified">Đã xác thực</span>
                </div>

                <div class="info-row">
                    <div class="info-label">Tên tài khoản</div>
                    <div class="info-value">@Model.UserName</div>
                </div>

                <div class="info-row">
                    <div class="info-label">Số điện thoại</div>
                    @if (string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div class="info-value empty">Chưa cập nhật</div>
                    }
                    else
                    {
                        <div class="info-value">@Model.PhoneNumber</div>
                    }
                </div>

                <div class="info-row">
                    <div class="info-label">Hạng thành viên</div>
                    <div class="info-value">
                        <span class="info-badge badge-verified">Thành viên</span>
                    </div>
                </div>
            </div>

            <!-- Security card -->
            <div class="profile-card" style="margin-top:1.4rem">
                <div class="profile-card-title">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    Bảo Mật Tài Khoản
                </div>

                <div class="info-row">
                    <div class="info-label">Mật khẩu</div>
                    <div class="info-value">••••••••••</div>
                    <a asp-action="ChangePassword" style="font-size:.74rem;letter-spacing:.1em;text-transform:uppercase;color:var(--charcoal);text-decoration:none;border-bottom:1px solid var(--light-gray)">Đổi</a>
                </div>
            </div>
        </div>

        <!-- Right: quick actions + danger -->
        <div>
            <div class="profile-card">
                <div class="profile-card-title">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 8v4M12 16h.01"/>
                    </svg>
                    Nhanh Chóng
                </div>

                <a asp-controller="Order" asp-action="Index" class="quick-action">
                    <div class="qa-icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                            <line x1="3" y1="6" x2="21" y2="6"/>
                            <path d="M16 10a4 4 0 0 1-8 0"/>
                        </svg>
                    </div>
                    <div class="qa-text">
                        <div class="qa-title">Đơn hàng của tôi</div>
                        <div class="qa-desc">Theo dõi & quản lý đơn hàng</div>
                    </div>
                    <div class="qa-arrow">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
                    </div>
                </a>

                <a asp-controller="Favourite" asp-action="Index" class="quick-action">
                    <div class="qa-icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                    </div>
                    <div class="qa-text">
                        <div class="qa-title">Sản phẩm yêu thích</div>
                        <div class="qa-desc">Danh sách wishlist của bạn</div>
                    </div>
                    <div class="qa-arrow">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
                    </div>
                </a>

                <a asp-controller="Cart" asp-action="Index" class="quick-action">
                    <div class="qa-icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                    </div>
                    <div class="qa-text">
                        <div class="qa-title">Giỏ hàng</div>
                        <div class="qa-desc">Xem sản phẩm đang chờ mua</div>
                    </div>
                    <div class="qa-arrow">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
                    </div>
                </a>

                <a asp-action="Edit" class="quick-action">
                    <div class="qa-icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                    </div>
                    <div class="qa-text">
                        <div class="qa-title">Chỉnh sửa hồ sơ</div>
                        <div class="qa-desc">Cập nhật thông tin cá nhân</div>
                    </div>
                    <div class="qa-arrow">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
                    </div>
                </a>
            </div>

            <!-- Danger zone -->
            <div class="danger-zone">
                <div class="danger-zone-title">⚠ Vùng nguy hiểm</div>
                <div class="danger-zone-desc">
                    Xóa tài khoản là hành động không thể hoàn tác.
                    Toàn bộ dữ liệu sẽ bị xóa vĩnh viễn.
                </div>
                <a asp-action="Delete" class="btn-danger">Xóa Tài Khoản</a>
            </div>
        </div>

    </div>
</div>
