@model Project_Essay_Course.ViewModels.Account_ViewModel.LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập";
}

@section Styles {
<style>
/* Reuse auth styles — copy from Register.cshtml or extract to _auth.css */
.auth-page {
    min-height: calc(100vh - var(--header-h));
    display: grid; grid-template-columns: 1fr 1fr;
}
.auth-visual { position: relative; overflow: hidden; background: var(--black); }
.auth-visual img { width: 100%; height: 100%; object-fit: cover; opacity: .5; }
.auth-visual-overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 4rem;
    background: linear-gradient(to top, rgba(10,10,10,.8) 0%, transparent 60%);
}
.auth-visual-quote {
    font-family: var(--serif); font-size: clamp(1.6rem,2.5vw,2.4rem);
    font-weight: 300; font-style: italic;
    color: var(--white); line-height: 1.35; margin-bottom: 1.2rem;
}
.auth-visual-credit { font-size: .72rem; letter-spacing: .18em; text-transform: uppercase; color: var(--stone); }
.auth-form-panel {
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    padding: 4rem 3rem; background: var(--white);
}
.auth-form-inner { width: 100%; max-width: 400px; }
.auth-eyebrow { font-size: .68rem; letter-spacing: .22em; text-transform: uppercase; color: var(--accent); margin-bottom: .8rem; }
.auth-title { font-family: var(--serif); font-size: clamp(1.8rem,3vw,2.6rem); font-weight: 300; color: var(--black); margin-bottom: .5rem; line-height: 1.15; }
.auth-title em { font-style: italic; }
.auth-subtitle { font-size: .85rem; color: #888; margin-bottom: 2.5rem; line-height: 1.6; }
.field-group { margin-bottom: 1.3rem; }
.field-label { display: block; font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; color: var(--charcoal); margin-bottom: .5rem; }
.field-input {
    width: 100%; padding: .85rem 1rem;
    border: 1px solid var(--light-gray); background: var(--white);
    font-family: var(--sans); font-size: .9rem; color: var(--black);
    outline: none; transition: border-color var(--transition);
}
.field-input:focus { border-color: var(--black); }
.field-error { font-size: .72rem; color: var(--danger); margin-top: .4rem; display: block; }
.field-input-wrap { position: relative; }
.eye-btn {
    position: absolute; right: .9rem; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer; color: #999;
    display: flex; padding: 0; transition: color .2s;
}
.eye-btn:hover { color: var(--black); }
.eye-btn svg { width: 18px; height: 18px; stroke-width: 1.4; }
.btn-auth {
    width: 100%; padding: .95rem;
    background: var(--black); color: var(--white);
    border: 1px solid var(--black);
    font-family: var(--sans); font-size: .78rem;
    font-weight: 400; letter-spacing: .16em; text-transform: uppercase;
    cursor: pointer; transition: background var(--transition), color var(--transition);
    margin-top: .5rem;
}
.btn-auth:hover { background: var(--white); color: var(--black); }
.val-summary {
    background: #fef2f2; border-left: 3px solid var(--danger);
    padding: .9rem 1rem; margin-bottom: 1.4rem;
    font-size: .82rem; color: var(--danger);
}
.val-summary ul { padding-left: 1.2rem; margin: 0; }
.auth-divider {
    display: flex; align-items: center; gap: 1rem; margin: 1.8rem 0;
}
.auth-divider::before, .auth-divider::after {
    content: ''; flex: 1; height: 1px; background: var(--light-gray);
}
.auth-divider span { font-size: .7rem; letter-spacing: .1em; text-transform: uppercase; color: #bbb; white-space: nowrap; }
.auth-alt { text-align: center; font-size: .82rem; color: #888; margin-top: 1.5rem; }
.auth-alt a { color: var(--black); font-weight: 500; text-decoration: none; border-bottom: 1px solid var(--black); transition: color .2s; }
.auth-alt a:hover { color: var(--accent); border-color: var(--accent); }

/* Login extras */
.field-row {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 1.8rem;
}
.remember-label {
    display: flex; align-items: center; gap: .5rem;
    font-size: .78rem; color: var(--charcoal); cursor: pointer;
}
.remember-label input[type=checkbox] { accent-color: var(--black); width: 15px; height: 15px; }
.forgot-link {
    font-size: .78rem; color: #888; text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color .2s, border-color .2s;
}
.forgot-link:hover { color: var(--black); border-color: var(--black); }

@@media (max-width: 768px) {
    .auth-page { grid-template-columns: 1fr; }
    .auth-visual { display: none; }
    .auth-form-panel { padding: 2.5rem 1.5rem; }
}
</style>
}

<div class="auth-page">

    <!-- Visual panel -->
    <div class="auth-visual">
        <img src="/image/image1.jpg" alt="Ngộ Store" />
        @* <div class="auth-visual-overlay">
            <div class="auth-visual-quote">
                "Ăn mặc tốt là một dạng<br>lịch sự với người khác."
            </div>
            <div class="auth-visual-credit">— Tom Ford</div>
        </div> *@
    </div>

    <!-- Form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-inner">

            <div class="auth-eyebrow">Chào mừng trở lại</div>
            <h1 class="auth-title"><em>Đăng Nhập</em></h1>
            <p class="auth-subtitle">Tiếp tục hành trình thời trang của bạn cùng NGỘ STORE.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="val-summary">
                    <ul>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="field-group">
                    <label class="field-label" asp-for="Email">Email</label>
                    <input asp-for="Email" type="email" class="field-input"
                           placeholder="example@email.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label class="field-label" asp-for="Password">Mật khẩu</label>
                    <div class="field-input-wrap">
                        <input asp-for="Password" type="password" class="field-input"
                               id="pwd-input" placeholder="••••••••"
                               autocomplete="current-password" />
                        <button type="button" class="eye-btn" onclick="togglePwd('pwd-input', this)">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="field-row">
                    <label class="remember-label">
                        <input asp-for="RememberMe" type="checkbox" />
                        Ghi nhớ đăng nhập
                    </label>
                    <a href="#" class="forgot-link">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn-auth">Đăng Nhập</button>
            </form>

            <div class="auth-divider"><span>Chưa có tài khoản?</span></div>

            <div class="auth-alt">
                <a asp-action="Register">Tạo tài khoản miễn phí →</a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePwd(inputId, btn) {
    const input = document.getElementById(inputId);
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    btn.querySelector('svg').style.opacity = isText ? '1' : '0.45';
}
</script>
}
