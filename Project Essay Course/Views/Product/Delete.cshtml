@model Project_Essay_Course.Models.Product
@{
    ViewData["Title"] = "Xóa Sản Phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

@section Styles {
<style>
.delete-page { max-width: 600px; margin: 3rem auto; padding: 0 2rem; }
.form-breadcrumb { display:flex; align-items:center; gap:.6rem; font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:#999; margin-bottom:2.5rem; }
.form-breadcrumb a { color:#999; text-decoration:none; transition:color .2s; }
.form-breadcrumb a:hover { color:var(--black); }
.form-breadcrumb svg { width:12px; height:12px; stroke-width:2; }

.delete-eyebrow { font-size:.68rem; letter-spacing:.22em; text-transform:uppercase; color:var(--danger); margin-bottom:.6rem; }
.delete-title   { font-family:var(--serif); font-size:clamp(1.6rem,3vw,2.4rem); font-weight:300; margin-bottom:2rem; }
.delete-title em { font-style:italic; color:var(--danger); }

.warning-banner { display:flex; gap:1rem; align-items:flex-start; padding:1.2rem 1.4rem; background:#fff5f5; border:1px solid rgba(192,57,43,.25); border-left:4px solid var(--danger); margin-bottom:2rem; }
.warning-icon { width:36px; height:36px; flex-shrink:0; display:flex; align-items:center; justify-content:center; background:rgba(192,57,43,.1); border-radius:50%; color:var(--danger); }
.warning-icon svg { width:18px; height:18px; stroke-width:2; }
.warning-text { font-size:.82rem; color:#8b2c2c; line-height:1.65; }
.warning-text strong { display:block; font-size:.86rem; margin-bottom:.3rem; }

/* Product preview */
.product-preview { display:flex; gap:1.2rem; align-items:center; border:1px solid var(--light-gray); padding:1.2rem; margin-bottom:2rem; background:var(--cream); }
.preview-img { width:64px; height:80px; object-fit:cover; flex-shrink:0; background:var(--white); }
.preview-img-placeholder { width:64px; height:80px; flex-shrink:0; background:var(--white); display:flex; align-items:center; justify-content:center; }
.preview-img-placeholder svg { width:24px; height:24px; color:var(--stone); stroke-width:1; }
.preview-name { font-family:var(--serif); font-size:1.1rem; font-weight:400; margin-bottom:.3rem; }
.preview-meta { font-size:.78rem; color:#999; }

.consequences { background:var(--cream); padding:1.2rem 1.4rem; margin-bottom:2rem; border:1px solid var(--stone); }
.consequences-title { font-size:.68rem; letter-spacing:.14em; text-transform:uppercase; color:var(--charcoal); margin-bottom:.7rem; }
.consequences ul { padding-left:0; margin:0; list-style:none; }
.consequences li { display:flex; gap:.6rem; font-size:.82rem; color:var(--charcoal); line-height:1.6; }
.consequences li::before { content:'✕'; color:var(--danger); font-size:.8rem; flex-shrink:0; margin-top:.1rem; }

.form-actions { display:flex; gap:1rem; align-items:center; }
.btn-delete-confirm { padding:.9rem 2rem; background:var(--danger); color:var(--white); border:1px solid var(--danger); font-family:var(--sans); font-size:.78rem; font-weight:400; letter-spacing:.16em; text-transform:uppercase; cursor:pointer; transition:background .25s; }
.btn-delete-confirm:hover { background:#a93226; border-color:#a93226; }
.btn-cancel-link { padding:.9rem 2rem; background:none; color:var(--charcoal); border:1px solid var(--light-gray); font-family:var(--sans); font-size:.78rem; letter-spacing:.16em; text-transform:uppercase; text-decoration:none; transition:all .25s; }
.btn-cancel-link:hover { border-color:var(--black); color:var(--black); }
</style>
}

<div class="delete-page">

    <div class="form-breadcrumb">
        <a asp-action="Manage">Sản phẩm</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <a asp-action="AdminDetail" asp-route-id="@Model.ProductId">@Model.Name</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>Xóa</span>
    </div>

    <div class="delete-eyebrow">⚠ Vùng nguy hiểm</div>
    <h1 class="delete-title">Xóa <em>Sản Phẩm</em></h1>

    <div class="warning-banner">
        <div class="warning-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <div class="warning-text">
            <strong>Hành động này không thể hoàn tác!</strong>
            Toàn bộ dữ liệu sản phẩm bao gồm ảnh và biến thể sẽ bị xóa vĩnh viễn.
        </div>
    </div>

    <div class="product-preview">
        @if (Model.MainImage != null)
        {
            <img class="preview-img" src="@Model.MainImage.ImagePath" alt="@Model.Name" />
        }
        else
        {
            <div class="preview-img-placeholder">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
        }
        <div>
            <div class="preview-name">@Model.Name</div>
            <div class="preview-meta">
                @Model.Category?.Name &nbsp;·&nbsp;
                @Model.BasePrice.ToString("N0")₫ &nbsp;·&nbsp;
                @Model.Variants.Count variant &nbsp;·&nbsp;
                @Model.Images.Count ảnh
            </div>
        </div>
    </div>

    <div class="consequences">
        <div class="consequences-title">Dữ liệu sẽ bị xóa vĩnh viễn</div>
        <ul>
            <li>Thông tin sản phẩm và mô tả</li>
            <li>@Model.Images.Count file ảnh trên server</li>
            <li>@Model.Variants.Count biến thể (tồn kho, giá)</li>
        </ul>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.ProductId" method="post">
        @Html.AntiForgeryToken()
        <div class="form-actions">
            <button type="submit" class="btn-delete-confirm">Xóa Vĩnh Viễn</button>
            <a asp-action="AdminDetail" asp-route-id="@Model.ProductId" class="btn-cancel-link">
                Hủy — Giữ Sản Phẩm
            </a>
        </div>
    </form>

</div>
