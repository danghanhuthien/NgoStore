@model Project_Essay_Course.Models.Product
@{
    ViewData["Title"] = "Chi Tiết: " + Model.Name;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

@section Styles {
<style>
.detail-admin-page { max-width: 1100px; margin: 3rem auto; padding: 0 2rem; }
.form-breadcrumb { display:flex; align-items:center; gap:.6rem; font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:#999; margin-bottom:2.5rem; }
.form-breadcrumb a { color:#999; text-decoration:none; transition:color .2s; }
.form-breadcrumb a:hover { color:var(--black); }
.form-breadcrumb svg { width:12px; height:12px; stroke-width:2; }

.admin-detail-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:2rem; flex-wrap:wrap; gap:1rem; }
.adt-title { font-family:var(--serif); font-size:clamp(1.6rem,3vw,2.4rem); font-weight:300; }
.adt-title em { font-style:italic; }
.adt-actions { display:flex; gap:.7rem; }
.btn-sm-action { display:inline-flex; align-items:center; gap:.4rem; padding:.65rem 1.3rem; border:1px solid var(--light-gray); background:none; font-family:var(--sans); font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; color:var(--charcoal); text-decoration:none; cursor:pointer; transition:all .2s; }
.btn-sm-action:hover { border-color:var(--black); color:var(--black); }
.btn-sm-action svg { width:13px; height:13px; stroke-width:2; }
.btn-sm-primary { background:var(--black); color:var(--white); border-color:var(--black); }
.btn-sm-primary:hover { background:var(--charcoal); color:var(--white); border-color:var(--charcoal); }
.btn-sm-danger { color:var(--danger); border-color:rgba(192,57,43,.3); }
.btn-sm-danger:hover { background:var(--danger); color:var(--white); border-color:var(--danger); }

.detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-bottom:2rem; }
.detail-card { border:1px solid var(--light-gray); padding:1.8rem 2rem; }
.detail-card-title { font-size:.7rem; letter-spacing:.2em; text-transform:uppercase; color:var(--accent); margin-bottom:1.5rem; padding-bottom:.8rem; border-bottom:1px solid var(--light-gray); }
.info-row { display:flex; padding:.75rem 0; border-bottom:1px solid rgba(235,235,235,.6); }
.info-row:last-child { border-bottom:none; }
.info-label { font-size:.68rem; letter-spacing:.12em; text-transform:uppercase; color:#bbb; width:130px; flex-shrink:0; padding-top:.1rem; }
.info-value { font-size:.88rem; color:var(--black); flex:1; }
.info-value.empty { color:#bbb; font-style:italic; }

.status-badge { display:inline-flex; align-items:center; gap:.35rem; padding:.25rem .7rem; font-size:.65rem; letter-spacing:.1em; text-transform:uppercase; }
.status-badge::before { content:''; width:6px; height:6px; border-radius:50%; }
.badge-active::before   { background:#16a34a; }
.badge-active    { color:#15803d; background:#f0fdf4; border:1px solid #bbf7d0; }
.badge-inactive::before { background:#bbb; }
.badge-inactive  { color:#777; background:#f5f5f5; border:1px solid #e0e0e0; }
.badge-featured  { background:var(--accent); color:var(--white); font-size:.62rem; padding:.2rem .6rem; }

/* Images */
.image-gallery-admin { display:grid; grid-template-columns:repeat(4,1fr); gap:.6rem; }
.img-admin-item { aspect-ratio:3/4; overflow:hidden; background:var(--cream); position:relative; }
.img-admin-item img { width:100%; height:100%; object-fit:cover; }
.img-main-badge { position:absolute; bottom:.3rem; left:.3rem; font-size:.6rem; letter-spacing:.08em; text-transform:uppercase; background:var(--accent); color:var(--white); padding:.2rem .5rem; }

/* Variants table */
.variants-table { width:100%; border-collapse:collapse; font-size:.83rem; }
.variants-table th { padding:.6rem .8rem; font-size:.63rem; letter-spacing:.14em; text-transform:uppercase; color:#999; font-weight:400; border-bottom:2px solid var(--light-gray); text-align:left; }
.variants-table td { padding:.75rem .8rem; border-bottom:1px solid rgba(235,235,235,.7); }
.stock-ok  { color:#15803d; font-weight:500; }
.stock-low { color:#f59e0b; font-weight:500; }
.stock-out { color:var(--danger); font-weight:500; }

@@media (max-width:768px) { .detail-grid { grid-template-columns:1fr; } .image-gallery-admin { grid-template-columns:repeat(3,1fr); } }
</style>
}

<div class="detail-admin-page">

    <div class="form-breadcrumb">
        <a asp-action="Manage">Sản phẩm</a>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 18l6-6-6-6"/></svg>
        <span>@Model.Name</span>
    </div>

    <div class="admin-detail-header">
        <div>
            <div style="font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:.4rem">Chi Tiết Sản Phẩm</div>
            <h1 class="adt-title"><em>@Model.Name</em></h1>
        </div>
        <div class="adt-actions">
            <a asp-action="Detail" asp-route-slug="@Model.Slug" target="_blank" class="btn-sm-action">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Xem ngoài shop
            </a>
            <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn-sm-action btn-sm-primary">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Chỉnh sửa
            </a>
            <a asp-action="Delete" asp-route-id="@Model.ProductId" class="btn-sm-action btn-sm-danger">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                Xóa
            </a>
        </div>
    </div>

    <div class="detail-grid">
        <div class="detail-card">
            <div class="detail-card-title">Thông Tin Cơ Bản</div>
            <div class="info-row"><div class="info-label">Tên</div><div class="info-value">@Model.Name</div></div>
            <div class="info-row"><div class="info-label">Slug</div><div class="info-value" style="font-family:monospace;font-size:.8rem;color:#888">/product/@Model.Slug</div></div>
            <div class="info-row"><div class="info-label">Danh mục</div><div class="info-value">@Model.Category?.Name</div></div>
            <div class="info-row"><div class="info-label">SKU</div><div class="info-value @(string.IsNullOrEmpty(Model.SKU) ? "empty" : "")">@(Model.SKU ?? "Chưa có")</div></div>
            <div class="info-row">
                <div class="info-label">Trạng thái</div>
                <div class="info-value">
                    @if (Model.IsActive) { <span class="status-badge badge-active">Đang bán</span> }
                    else { <span class="status-badge badge-inactive">Đã ẩn</span> }
                    @if (Model.IsFeatured) { <span class="status-badge badge-featured" style="margin-left:.4rem">Nổi bật</span> }
                </div>
            </div>
            <div class="info-row"><div class="info-label">Tạo lúc</div><div class="info-value">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
            <div class="info-row"><div class="info-label">Cập nhật</div><div class="info-value">@Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
        </div>

        <div class="detail-card">
            <div class="detail-card-title">Giá & Tồn Kho</div>
            <div class="info-row"><div class="info-label">Giá gốc</div><div class="info-value">@Model.BasePrice.ToString("N0")₫</div></div>
            <div class="info-row">
                <div class="info-label">Giá sale</div>
                <div class="info-value">
                    @if (Model.SalePrice.HasValue)
                    { <span style="color:#c0392b;font-weight:500">@Model.SalePrice.Value.ToString("N0")₫</span>
                      <span style="font-size:.75rem;color:#bbb;margin-left:.5rem">(-@Model.DiscountPercent%)</span> }
                    else
                    { <span class="empty">Không có sale</span> }
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Tồn kho</div>
                <div class="info-value">
                    @if (Model.TotalStock > 10) { <span class="stock-ok">@Model.TotalStock</span> }
                    else if (Model.TotalStock > 0) { <span class="stock-low">@Model.TotalStock ⚠</span> }
                    else { <span class="stock-out">Hết hàng</span> }
                </div>
            </div>
            <div class="info-row"><div class="info-label">Số variant</div><div class="info-value">@Model.Variants.Count</div></div>
            <div class="info-row"><div class="info-label">Số ảnh</div><div class="info-value">@Model.Images.Count</div></div>
        </div>
    </div>

    @if (Model.Images.Any())
    {
        <div class="detail-card" style="margin-bottom:2rem">
            <div class="detail-card-title">Hình Ảnh (@Model.Images.Count)</div>
            <div class="image-gallery-admin">
                @foreach (var img in Model.Images)
                {
                    <div class="img-admin-item">
                        <img src="@img.ImagePath" alt="@img.AltText" />
                        @if (img.IsMain) { <span class="img-main-badge">Đại diện</span> }
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.Variants.Any())
    {
        <div class="detail-card" style="margin-bottom:2rem">
            <div class="detail-card-title">Biến Thể (@Model.Variants.Count)</div>
            <table class="variants-table">
                <thead>
                    <tr>
                        <th>Phân loại</th>
                        <th>SKU</th>
                        <th>Tồn kho</th>
                        <th>Giá riêng</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Variants)
                    {
                        <tr>
                            <td>@v.DisplayName</td>
                            <td style="font-family:monospace;font-size:.78rem;color:#888">@(v.SKU ?? "—")</td>
                            <td>
                                @if (v.StockQty > 10) { <span class="stock-ok">@v.StockQty</span> }
                                else if (v.StockQty > 0) { <span class="stock-low">@v.StockQty</span> }
                                else { <span class="stock-out">0</span> }
                            </td>
                            <td>@(v.PriceOverride.HasValue ? v.PriceOverride.Value.ToString("N0") + "₫" : "—")</td>
                            <td>
                                @if (v.IsActive) { <span class="status-badge badge-active">Active</span> }
                                else { <span class="status-badge badge-inactive">Ẩn</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="detail-card">
            <div class="detail-card-title">Mô Tả Chi Tiết</div>
            <div style="font-size:.88rem;color:var(--charcoal);line-height:1.75">@Html.Raw(Model.Description)</div>
        </div>
    }

</div>
